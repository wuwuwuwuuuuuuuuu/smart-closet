<!-- 服饰上传弹窗组件 -->
<view class="upload-modal {{show ? 'show' : ''}}" catchtap="hideModal">
  <view class="modal-content" catchtap="">
    <!-- 上半区：拍照引导预览区 -->
    <view class="preview-section">
      <view class="preview-overlay">
        <view class="preview-frame">
          <!-- 示例图或拍照预览 -->
          <image wx:if="{{!uploading && !uploadedImage}}" src="cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/upload-guide.jpg" class="guide-image" mode="aspectFill" />
          <image wx:if="{{uploadedImage}}" src="{{uploadedImage}}" class="guide-image" mode="aspectFill" />
          
          <!-- 倒计时提示 -->
          <view class="countdown" wx:if="{{showCountdown}}">
            <text class="countdown-number">{{countdown}}</text>
          </view>
          
          <!-- 引导文字 -->
          <view class="guide-text">
            <text class="main-guide">{{currentGuide.main}}</text>
            <text class="sub-guide">{{currentGuide.sub}}</text>
          </view>
        </view>
      </view>
      
      <!-- 进度条 -->
      <view class="progress-bar" wx:if="{{uploading}}">
        <view class="progress-fill" style="width: {{uploadProgress}}%"></view>
      </view>
    </view>
    
    <!-- 下半区：上传选项列表 -->
    <view class="options-section">
      <!-- 标题栏 -->
      <view class="title-bar">
        <text class="title">上传方式</text>
        <view class="fast-upload-switch">
          <text class="switch-label">极速上传</text>
          <switch checked="{{fastUpload}}" bindchange="toggleFastUpload" color="#4CAF50" />
        </view>
      </view>
      
      <!-- 上传选项 -->
      <view class="upload-options">
        <view class="option-item" bindtap="chooseCamera">
          <text class="option-text">拍照上传</text>
        </view>
        <view class="option-item" bindtap="chooseAlbum">
          <text class="option-text">相册导入</text>
        </view>
      </view>
      
      <!-- 取消按钮 -->
      <view class="cancel-btn" bindtap="hideModal">
        <text class="cancel-text">取消</text>
      </view>
    </view>
  </view>
</view>