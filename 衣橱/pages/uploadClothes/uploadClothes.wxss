/* 服饰上传页面样式 */
.container {
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  min-height: 100vh;
}



/* 拍照引导区 */
.guide-section {
  margin-bottom: 32rpx;
}

.guide-card {
  background: #EDEDED;
  border-radius: 12rpx;
  padding: 32rpx;
}

.guide-frame {
  width: 100%;
  height: 400rpx;
  border: 2rpx solid #333333;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
  background: rgba(0, 0, 0, 0.5);
}

.guide-image {
  width: 100%;
  height: 100%;
}

.guide-text {
  position: absolute;
  bottom: 32rpx;
  left: 0;
  right: 0;
  text-align: center;
  z-index: 10;
}

.main-guide {
  font-size: 28rpx;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
}

.sub-guide {
  font-size: 24rpx;
  color: #999999;
  display: block;
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
}

/* 进度条 */
.progress-bar {
  margin-top: 16rpx;
  height: 4rpx;
  background: #E0E0E0;
  border-radius: 2rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #E0F7E9 0%, #4CAF50 100%);
  transition: width 0.3s ease;
}

/* 上传选项区 */
.options-section {
  margin-bottom: 32rpx;
}

.option-card {
  background: #EDEDED;
  border-radius: 12rpx;
  padding: 24rpx;
}

.option-item {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.option-item:active {
  background: #F8F9FA;
  transform: scale(0.98);
}

.option-item:last-child {
  margin-bottom: 0;
}

.option-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 16rpx;
}

.option-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.option-desc {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}

/* 底部提示 */
.bottom-hint {
  text-align: center;
  padding: 24rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #999999;
}