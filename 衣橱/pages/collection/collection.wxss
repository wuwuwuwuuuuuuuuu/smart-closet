/* 我的收藏页面样式 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.gradient-bg {
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F0FF 100%);
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
}

/* 搜索框 */
.search-section {
  padding: 20rpx;
  background: #FFFFFF;
  box-sizing: border-box;
}

.search-box {
  position: relative;
  margin: 0;
}

.search-input {
  width: 100%;
  height: 64rpx;
  background: #EDEDED;
  border-radius: 12rpx;
  padding: 0 64rpx 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 24rpx;
  height: 24rpx;
}

/* 收藏列表 */
.collection-list {
  flex: 1;
  padding: 2rpx;
}

.grid-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.collection-item {
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  height: 320rpx;
  display: flex;
  flex-direction: column;
}

.collection-image {
  width: 100%;
  height: 250rpx;
  flex-shrink: 0;
  object-fit: cover;
}

.tag-list {
  padding: 1rpx 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  flex: 1;
  align-items: center;
}

.tag {
  padding: 2rpx 10rpx;
  background: #EDEDED;
  border-radius: 10rpx;
  font-size: 23rpx;
  color: #666666;
  line-height: 1;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-height: 32rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}