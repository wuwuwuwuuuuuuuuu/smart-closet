/* 试穿预览页样式 */
.container {
  position: relative;
  height: 100vh;
  overflow: hidden;
}

/* 顶部导航 */
.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.9);
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 预览区域 */
.preview-area {
  width: 100%;
  height: 100%;
  position: relative;
}

.preview-container {
  width: 100%;
  height: 100%;
  position: relative;
}

.background-image {
  width: 100%;
  height: 100%;
}

/* 试穿照片显示 */
.tryon-display {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tryon-image {
  max-width: 90%;
  max-height: 90%;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

/* 无试穿照片提示 */
.no-tryon-section {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
}

.no-tryon-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.no-tryon-text {
  font-size: 28rpx;
  color: #5D6D7E;
}

/* 生成海报按钮 */
.generate-btn {
  position: absolute;
  right: 32rpx;
  bottom: 120rpx;
  background: #EDEDED;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 99;
}

.generate-icon {
  width: 24rpx;
  height: 24rpx;
}

.generate-text {
  font-size: 24rpx;
  color: #333333;
}

/* 背景选择弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 80%;
  max-height: 70%;
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #E0E0E0;
}

.modal-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
}

.modal-close {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999999;
}

.background-options {
  padding: 32rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.background-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: 8rpx;
}

.background-item.active {
  border-color: #333333;
  background: #EDEDED;
}

.background-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 6rpx;
  margin-right: 20rpx;
}

.background-name {
  font-size: 28rpx;
  color: #333333;
}

.modal-actions {
  padding: 32rpx;
  display: flex;
  gap: 20rpx;
}

.modal-actions .btn {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.btn-secondary {
  background: #EDEDED;
  color: #333333;
}

.btn-primary {
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F0FF 100%);
  color: #333333;
}