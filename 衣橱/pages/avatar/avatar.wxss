/* 我的形象页面样式 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #F8F9FA 0%, #EDEDED 100%);
}

/* 页面标题 */
.page-header {
  padding: 60rpx 20rpx 40rpx;
  text-align: center;
}

.page-title {
  font-size: 36rpx;
  color: #333333;
  font-weight: 700;
  margin-bottom: 16rpx;
  display: block;
}

.page-subtitle {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
  display: block;
}

/* 形象预览 */
.avatar-preview {
  flex: 1;
  padding: 0 20rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-container {
  width: 100%;
  height: 500rpx;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-frame {
  width: 100%;
  height: 100%;
  background: #FFFFFF;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  border: 2rpx dashed #E0E0E0;
  transition: all 0.3s ease;
}

.preview-container:active .preview-frame {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.avatar-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.upload-placeholder {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.upload-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.7;
}

.upload-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  display: block;
}

.upload-hint {
  font-size: 24rpx;
  color: #999999;
  display: block;
  line-height: 1.4;
}

/* 创建按钮 */
.create-section {
  padding: 0 20rpx 60rpx;
}

.create-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F0FF 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 232, 232, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.create-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.create-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(255, 232, 232, 0.2);
}

.create-btn:active::before {
  left: 100%;
}

.create-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  letter-spacing: 2rpx;
}