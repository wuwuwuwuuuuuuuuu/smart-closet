<!-- 生成历史页面 -->
<view class="container">
  <!-- 历史列表 -->
  <scroll-view 
    class="history-list" 
    scroll-y="true" 
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onLoadMore">
    
    <view class="grid-container">
      <view 
        class="history-item" 
        wx:for="{{historyList}}" 
        wx:key="id"
        bindtap="goToPoster"
        data-item="{{item}}">
        
        <!-- 选择圆圈（仅在选择模式下显示） -->
        <view class="selection-circle {{item.selected ? 'selected' : ''}}" wx:if="{{isSelectionMode}}">
          <view class="circle-inner"></view>
        </view>
        
        <image src="{{item.image}}" class="history-image" mode="aspectFill" />
        <text class="history-date">{{item.date}}</text>
      </view>
    </view>

    <!-- 加载更多提示 -->
    <view class="load-more" wx:if="{{loadingMore}}">
      <text class="load-more-text">加载中...</text>
    </view>

    <view class="no-more" wx:if="{{noMoreData && historyList.length > 0}}">
      <text class="no-more-text">没有更多数据了</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{historyList.length === 0 && !loadingMore}}">
      <text class="empty-text">暂无生成记录</text>
    </view>
  </scroll-view>
</view>