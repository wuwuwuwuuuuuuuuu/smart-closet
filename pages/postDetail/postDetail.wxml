<view class="container">
  <view class="nav-bar">
    <view class="nav-right" wx:if="{{isAuthor}}" bindtap="showDeleteConfirm">
      <image src="data:image/svg+xml;base64," class="nav-icon" />
    </view>
  </view>

  <scroll-view class="content-scroll" scroll-y="true">
    <view class="image-swiper-section">
      <swiper class="post-swiper" indicator-dots="{{false}}" autoplay="{{false}}" circular="{{false}}" duration="300" bindchange="onSwiperChange">
        <swiper-item wx:for="{{post.images || [post.image]}}" wx:key="*this">
          <image src="{{item}}" class="swiper-image" mode="aspectFill" bindtap="previewImage" data-images="{{post.images || [post.image]}}" data-index="{{index}}" />
        </swiper-item>
      </swiper>
      <view class="swiper-indicator" wx:if="{{post.images && post.images.length > 1}}">
        <text class="indicator-text">{{currentImageIndex + 1}}/{{post.images.length}}</text>
      </view>
    </view>
    
    <view class="post-info">
      <text class="post-title" wx:if="{{post.title}}">{{post.title}}</text>
      <text class="post-content" wx:if="{{post.content}}">{{post.content}}</text>
      <view class="post-meta-bottom">
        <text class="post-time">{{post.time}}</text>
      </view>
    </view>

    <view class="comment-section" id="comment-section">
      <text class="section-title">共 {{comments.length > 0 ? comments.length : 0}} 条评论</text>
      
      <view class="comment-list">
        <view class="comment-item" wx:for="{{comments}}" wx:key="id" wx:for-index="index" wx:for-item="item">
          <view class="comment-main">
            <image wx:if="{{item.avatar}}" src="{{item.avatar}}" class="comment-avatar" mode="aspectFill" />
            <view class="comment-body">
              <text class="comment-author">{{item.author}}</text>
              <text class="comment-content" catchtap="handleReply" data-comment="{{item}}">{{item.content}}</text>
              
              <view class="comment-footer">
                <view class="time-reply">
                  <text class="comment-time">{{item.time}}</text>
                  <text class="reply-text" catchtap="handleReply" data-comment="{{item}}">回复</text>
                </view>
                <view class="comment-like" bindtap="toggleCommentLike" data-id="{{item.id}}">
                  <image wx:if="{{item.liked}}" src="data:image/svg+xml;base64," class="comment-like-icon" />
                  <image wx:else src="data:image/svg+xml;base64," class="comment-like-icon" />
                  <text class="comment-like-count {{item.liked ? 'liked-text' : ''}}">{{item.likes > 0 ? item.likes : 0}}</text>
                </view>
              </view>

              <view class="expand-btn" wx:if="{{item.replies && item.replies.length > 0 && !item.isExpanded}}" catchtap="toggleExpand" data-index="{{index}}">
                <text class="expand-text">—— 展开 {{item.replies.length}} 条回复 <text class="arrow">∨</text></text>
              </view>

              <view class="reply-list" wx:if="{{item.replies && item.replies.length > 0 && item.isExpanded}}">
                <view class="reply-item" wx:for="{{item.replies}}" wx:key="id" wx:for-item="reply">
                  <image wx:if="{{reply.avatar}}" src="{{reply.avatar}}" class="reply-avatar" mode="aspectFill" />
                  <view class="reply-body">
                    <view class="reply-header">
                      <text class="reply-author">{{reply.author}}</text>
                      <block wx:if="{{reply.replyTo}}">
                        <text class="reply-to">回复</text>
                        <text class="reply-target">{{reply.replyTo}}</text>
                      </block>
                    </view>
                    <text class="reply-content" catchtap="handleReply" data-comment="{{reply}}" data-rootid="{{item.id}}">{{reply.content}}</text>
                    
                    <view class="comment-footer">
                      <view class="time-reply">
                        <text class="reply-time">{{reply.time}}</text>
                        <text class="reply-text" catchtap="handleReply" data-comment="{{reply}}" data-rootid="{{item.id}}">回复</text>
                      </view>
                      <view class="reply-like" bindtap="toggleReplyLike" data-comment-id="{{item.id}}" data-reply-id="{{reply.id}}">
                        <image wx:if="{{reply.liked}}" src="data:image/svg+xml;base64," class="reply-like-icon" />
                        <image wx:else src="data:image/svg+xml;base64," class="reply-like-icon" />
                        <text class="reply-like-count {{reply.liked ? 'liked-text' : ''}}">{{reply.likes > 0 ? reply.likes : 0}}</text>
                      </view>
                    </view>
                  </view>
                </view>

                <view class="collapse-btn" catchtap="toggleExpand" data-index="{{index}}">
                  <text class="expand-text">—— 收起 <text class="arrow">∧</text></text>
                </view>
              </view>

            </view>
          </view>
        </view>
      </view>
      <view style="height: 140rpx;"></view>
    </view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="input-section {{isInputFocused || commentText.length > 0 ? 'expanded' : ''}}">
      <image wx:if="{{!isInputFocused && commentText.length === 0}}" src="data:image/svg+xml;base64," class="input-icon" />
      <input class="comment-input" placeholder="{{replyTarget ? '回复 @' + replyTarget.userName : '说点什么...'}}" bindinput="onCommentInput" bindfocus="onInputFocus" bindblur="onInputBlur" bindconfirm="sendCommentOrReply" confirm-type="send" focus="{{isInputFocused}}" value="{{commentText}}" />
    </view>
    
    <view class="action-section" wx:if="{{!isInputFocused && commentText.length === 0}}">
      <view class="action-btn" catchtap="toggleLike">
        <image wx:if="{{post.liked}}" src="data:image/svg+xml;base64," class="action-icon" />
        <image wx:else src="data:image/svg+xml;base64," class="action-icon" />
        <text class="action-text {{post.liked ? 'liked-text' : ''}}">{{post.likes > 0 ? post.likes : 0}}</text>
      </view>
      
      <view class="action-btn" catchtap="toggleCollect">
        <image wx:if="{{post.collected}}" src="data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0iI0ZGQzEwNyI+PHBhdGggZD0iTTEyIDE3LjI3TDE4LjE4IDIxbC0xLjY0LTcuMDNMMjIgOS4yNGwtNy4xOS0uNjFMMTIgMiA5LjE5IDguNjMgMiA5LjI0bDUuNDYgNC43My0xLjY0IDcuMDNMMTIgMTcuMjd6Ii8+PC9zdmc+" class="action-icon" />
        <image wx:else src="data:image/svg+xml;base64," class="action-icon" />
        <text class="action-text {{post.collected ? 'collected-text' : ''}}">{{post.collects > 0 ? post.collects : 0}}</text>
      </view>
      
      <view class="action-btn" catchtap="scrollToComments">
        <image src="data:image/svg+xml;base64," class="action-icon" />
        <text class="action-text">{{comments.length > 0 ? comments.length : 0}}</text>
      </view>
    </view>

    <view class="send-btn" wx:if="{{isInputFocused || commentText.length > 0}}" catchtap="sendCommentOrReply">发送</view>
  </view>
</view>
