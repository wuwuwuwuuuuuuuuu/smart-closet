/* 服饰上传页面样式 */
.container {
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  min-height: 100vh;
}



/* 拍照引导区 */
.guide-section {
  margin-bottom: 32rpx;
}

.guide-card {
  background: #EDEDED;
  border-radius: 12rpx;
  padding: 32rpx;
}

.guide-frame {
  width: 100%;
  height: 400rpx;
  border: 2rpx solid #333333;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
  background: rgba(0, 0, 0, 0.5);
}

.guide-image {
  width: 100%;
  height: 100%;
}

.guide-text {
  position: absolute;
  bottom: 32rpx;
  left: 0;
  right: 0;
  text-align: center;
  z-index: 10;
}

.main-guide {
  font-size: 28rpx;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
}

.sub-guide {
  font-size: 24rpx;
  color: #999999;
  display: block;
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
}

/* 进度条 */
.progress-bar {
  margin-top: 16rpx;
  height: 4rpx;
  background: #E0E0E0;
  border-radius: 2rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #E0F7E9 0%, #4CAF50 100%);
  transition: width 0.3s ease;
}

/* 上传选项区 */
.options-section {
  margin-bottom: 32rpx;
}

.option-card {
  background: #EDEDED;
  border-radius: 12rpx;
  padding: 24rpx;
}

.option-item {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.option-item:active {
  background: #F8F9FA;
  transform: scale(0.98);
}

.option-item:last-child {
  margin-bottom: 0;
}

.option-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 16rpx;
}

.option-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.option-desc {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}

/* 底部提示 */
.bottom-hint {
  text-align: center;
  padding: 24rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #999999;
}

/* Visual refresh */
page {
  background: linear-gradient(180deg, #f8faf6 0%, #edf7f2 100%);
}

.container {
  padding: 28rpx 24rpx 48rpx;
  background: transparent;
}

.guide-section,
.options-section {
  animation: fadeUp 520ms ease both;
}

.options-section {
  animation-delay: 90ms;
}

.guide-card,
.option-card {
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 18rpx 40rpx rgba(37, 49, 44, 0.08);
}

.guide-frame {
  height: 430rpx;
  border: 0;
  border-radius: 26rpx;
  background: #26312c;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.22);
}

.main-guide {
  color: #ffffff;
  font-weight: 800;
  text-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.28);
}

.sub-guide {
  color: rgba(255, 255, 255, 0.82);
  text-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.28);
}

.progress-bar {
  height: 8rpx;
  border-radius: 999rpx;
  background: #e5eee9;
}

.progress-fill {
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2f9c7d 0%, #6fb7ff 100%);
}

.option-item {
  border-radius: 26rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f1f8f4 100%);
  box-shadow: 0 10rpx 24rpx rgba(37, 49, 44, 0.06);
}

.option-item:active {
  background: #eff7f2;
}

.option-icon {
  width: 70rpx;
  height: 70rpx;
}

.option-text {
  color: #26312c;
  font-weight: 800;
}

.option-desc,
.hint-text {
  color: #718078;
}
