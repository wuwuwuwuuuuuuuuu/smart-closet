/* 首页样式 - 优化布局和尺寸 */
.container {
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #EDEDED;
}

/* 顶部轮播图 */
.swiper-container {
  margin: 40rpx 0;
  height: 400rpx;
}
swiper {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  overflow: hidden;
}
.swiper-image {
  width: 100%;
  height: 150%;
  object-fit: contain;
  display: block;
}
/* 智能推荐卡片 */
.diary-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 32rpx;
  margin: 32rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 120rpx;
}

.diary-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  font-family: PingFang SC;
}

.diary-icon {
  width: 144rpx;
  height: 144rpx;
  margin-left: 16rpx;
}

/* 功能按钮区 */
.function-grid {
  display: flex;
  justify-content: space-between;
  margin: 32rpx 0;
}

.function-item {
  flex: 0 0 48%;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 48rpx 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 240rpx;
}

.function-icon {
  width: 192rpx;
  height: 192rpx;
  margin-bottom: 24rpx;
}

.function-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: 400;
  font-family: PingFang SC;
}

/* 商品试穿按钮 */
.product-btn {
  width: 100%;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 32rpx 0;
  min-height: 120rpx;
}

.product-icon {
  width: 144rpx;
  height: 144rpx;
  margin-right: 40rpx;
}

.product-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: 400;
  font-family: PingFang SC;
}
