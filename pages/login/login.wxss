page {
  background-color: #f8f9fa;
  height: 100vh;
}

.login-container {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100vh;
  padding: 80rpx 60rpx;
  box-sizing: border-box;
}

.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 150rpx;
}

.logo-placeholder {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  text-shadow: 0 10rpx 20rpx rgba(0,0,0,0.1);
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
  text-align: center;
}

.bottom-section {
  margin-bottom: 100rpx;
  width: 100%;
}

.wechat-btn {
  background: linear-gradient(135deg, #07c160, #06ad56);
  border-radius: 50rpx;
  box-shadow: 0 15rpx 30rpx rgba(7, 193, 96, 0.3);
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  width: 100% !important;
}

.btn-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.tips {
  margin-top: 40rpx;
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
}