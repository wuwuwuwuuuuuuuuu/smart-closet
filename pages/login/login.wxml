<view class="login-container">
  <view class="main-content">
    <image class="logo-image" src="data:image/svg+xml;base64," mode="aspectFit" />
    
    <view class="text-group">
      <view class="title">衣智焕新</view>
      <view class="subtitle">每一套穿搭，都是爱自己的一种方式。\n装下你的衣橱，清空你的焦虑。</view>
    </view>
  </view>

  <view class="bottom-section">
    <button class="wechat-btn" bindtap="handleLogin">
      <text class="btn-text">微信一键安全登录</text>
    </button>
    
    <view class="tips">
      <text>登录即表示同意《用户服务协议》与《隐私政策》</text>
    </view>
  </view>
</view>