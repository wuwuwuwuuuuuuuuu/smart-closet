<!-- 社区页面 -->
<view class="container">
  <!-- 帖子列表 -->
  <scroll-view 
    class="post-list" 
    scroll-y="true" 
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onLoadMore">
    
    <view class="grid-container">
      <view 
        class="post-card" 
        wx:for="{{postList}}" 
        wx:key="id"
        bindtap="goToPostDetail"
        data-id="{{item.id}}">
        
        <image src="{{item.image}}" class="post-image" mode="aspectFill" />
        <view class="post-info">
          <text class="post-title">{{item.title}}</text>
          <view class="post-meta">
            <text class="post-author">{{item.author}}</text>
            <view class="like-info">
              <image 
                src="{{item.liked ? 'cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img28.png' : 'cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img27.png'}}" 
                class="like-icon" />
              <text class="like-count">{{item.likes}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 加载更多提示 -->
    <view class="load-more" wx:if="{{loadingMore}}">
      <text class="load-text">加载中...</text>
    </view>
    
    <view class="no-more" wx:if="{{noMoreData}}">
      <text class="no-more-text">没有更多内容了</text>
    </view>
  </scroll-view>

  <!-- 右下角发布按钮 -->
  <view class="publish-btn" bindtap="goToPostEdit">
    <image src="cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img24.png" class="publish-icon" />
    <text class="publish-text">晒穿搭</text>
  </view>
</view>