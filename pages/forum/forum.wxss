page {
  background: linear-gradient(180deg, #f8faf6 0%, #edf6f2 100%);
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: transparent;
  padding: 0;
}

.header {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
}

.gradient-bg {
  background: linear-gradient(135deg, #ffb199 0%, #2f9c7d 100%);
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #26312c;
}

.post-list {
  flex: 1;
  height: 100vh;
  padding: 22rpx 18rpx 160rpx;
  box-sizing: border-box;
}

.grid-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.post-card {
  width: 100%;
  overflow: hidden;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 16rpx 36rpx rgba(35, 48, 42, 0.1);
  transition: transform 180ms ease, box-shadow 180ms ease;
  animation: fadeUp 520ms ease both;
}

.post-card:nth-child(2n) {
  animation-delay: 80ms;
}

.post-card:active {
  transform: translateY(4rpx) scale(0.98);
  box-shadow: 0 8rpx 20rpx rgba(35, 48, 42, 0.08);
}

.post-image {
  width: 100%;
  height: 350rpx;
  background: #eef3ef;
  display: block;
}

.post-info {
  padding: 20rpx 18rpx 18rpx;
}

.post-title {
  min-height: 70rpx;
  margin-bottom: 14rpx;
  color: #26312c;
  display: -webkit-box;
  overflow: hidden;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.post-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 2rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(38, 49, 44, 0.12);
}

.post-author {
  flex: 1;
  overflow: hidden;
  color: #76827b;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.like-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: #f4f7f4;
}

.like-icon {
  width: 20rpx;
  height: 20rpx;
}

.like-count {
  color: #7f8c85;
  font-size: 20rpx;
}

.load-more,
.no-more {
  text-align: center;
  padding: 42rpx 0;
}

.load-text,
.no-more-text {
  color: #8a9690;
  font-size: 24rpx;
}

.publish-btn {
  position: fixed;
  right: 30rpx;
  bottom: 132rpx;
  min-height: 88rpx;
  padding: 0 30rpx;
  z-index: 99;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #ff7f6e 0%, #2f9c7d 100%);
  box-shadow: 0 20rpx 42rpx rgba(47, 156, 125, 0.26);
  animation: softPulse 2.8s ease-in-out infinite;
  transition: transform 180ms ease;
}

.publish-btn:active {
  transform: scale(0.96);
}

.publish-icon {
  width: 34rpx;
  height: 34rpx;
}

.publish-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}
