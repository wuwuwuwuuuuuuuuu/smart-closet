/* 社区页面样式 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

/* 顶部标题 */
.header {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
}

.gradient-bg {
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F0FF 100%);
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

/* 帖子列表 */
.post-list {
  flex: 1;
  padding: 4rpx;
  height: 100vh;
}

.grid-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.post-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  width: 100%;
}

.post-image {
  width: 100%;
  height: 360rpx;
  object-fit: cover;
}

.post-info {
  padding: 20rpx 16rpx 16rpx;
}

.post-title {
  font-size: 26rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  min-height: 72rpx;
}

.post-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.author-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.post-author {
  font-size: 22rpx;
  color: #999999;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.like-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.like-icon {
  width: 18rpx;
  height: 18rpx;
}

.like-count {
  font-size: 20rpx;
  color: #999999;
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 40rpx 0;
}

.load-text, .no-more-text {
  font-size: 24rpx;
  color: #999999;
}

/* 发布按钮 */
.publish-btn {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 99;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.publish-icon {
  width: 32rpx;
  height: 32rpx;
}

.publish-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}