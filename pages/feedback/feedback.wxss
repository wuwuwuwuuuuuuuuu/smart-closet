/* 反馈页面样式 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
  padding: 0 20rpx;
}

/* 页面标题 */
.header {
  padding: 60rpx 0 40rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999999;
  display: block;
}

/* 分区样式 */
.section {
  margin-bottom: 40rpx;
}

.section-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 20rpx;
  display: block;
}

/* 反馈类型选择 */
.type-selector {
  display: flex;
  gap: 20rpx;
}

.type-item {
  flex: 1;
  height: 120rpx;
  background: #F8F8F8;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.type-item.active {
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F1FF 100%);
  border-color: #FF6B6B;
}

.type-icon {
  width: 32rpx;
  height: 32rpx;
  margin-bottom: 12rpx;
}

.type-text {
  font-size: 24rpx;
  color: #666666;
}

.type-item.active .type-text {
  color: #333333;
  font-weight: 500;
}

/* 反馈内容输入 */
.feedback-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #F8F8F8;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.feedback-textarea:focus {
  border-color: #FF6B6B;
  background: #FFFFFF;
}

.word-count {
  font-size: 24rpx;
  color: #999999;
  text-align: right;
  margin-top: 12rpx;
}

/* 联系方式输入 */
.contact-input {
  width: 100%;
  height: 80rpx;
  background: #F8F8F8;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.contact-input:focus {
  border-color: #FF6B6B;
  background: #FFFFFF;
}

/* 占位符样式 */
.placeholder {
  color: #CCCCCC;
}

/* 提交按钮 */
.submit-section {
  margin-top: 60rpx;
  padding: 0 20rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: #E0E0E0;
  border-radius: 44rpx;
  border: none;
  font-size: 32rpx;
  color: #999999;
  transition: all 0.3s ease;
}

.submit-btn.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #4ECDC4 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}

.submit-btn:active {
  transform: scale(0.98);
}

/* 响应式调整 */
@media (max-width: 375px) {
  .type-selector {
    flex-direction: column;
  }
  
  .type-item {
    height: 100rpx;
    flex-direction: row;
    justify-content: flex-start;
    padding: 0 24rpx;
  }
  
  .type-icon {
    margin-bottom: 0;
    margin-right: 16rpx;
  }
}