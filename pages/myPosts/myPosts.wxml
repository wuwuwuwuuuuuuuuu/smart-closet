<view class="container">
  <view class="tab-bar">
    <view 
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      bindtap="switchTab"
      data-tab="{{item.key}}">
      <text class="tab-text">{{item.label}}</text>
      <view class="tab-line"></view>
    </view>
  </view>

  <scroll-view 
    class="post-list" 
    scroll-y="true" 
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh">
    
    <view class="grid-container">
      <view 
        class="post-card" 
        wx:for="{{currentPosts}}" 
        wx:key="id"
        bindtap="goToPostDetail"
        bindlongpress="showPostOptions"
        data-id="{{item.id}}"
        data-index="{{index}}">
        
        <image src="{{item.image}}" class="post-image" mode="aspectFill" />
        <view class="post-info">
          <text class="post-title">{{item.title}}</text>
          <view class="post-meta">
            <text class="post-time">{{item.time}}</text>
            <view class="like-info">
              <image 
                src="{{item.liked ? 'cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img28.png' : 'cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img27.png'}}" 
                class="like-icon" />
              <text class="like-count">{{item.likes}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <view class="empty-state" wx:if="{{currentPosts.length === 0}}">
      <text class="empty-text">{{emptyText}}</text>
      <text class="empty-hint">{{emptyHint}}</text>
    </view>
  </scroll-view>

  <view class="modal {{showOptionsModal ? 'show' : ''}}" bindtap="hideOptionsModal">
    <view class="modal-content options-modal" catchtap="">
      <view class="option-item delete" bindtap="deletePost">
        <text class="option-text">删除</text>
      </view>
      <view class="option-item cancel" bindtap="hideOptionsModal">
        <text class="option-text">取消</text>
      </view>
    </view>
  </view>
</view>
