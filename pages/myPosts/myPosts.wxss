/* 我的帖子页面样式 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #EDEDED;
}

/* 帖子列表 */
.post-list {
  flex: 1;
  padding: 40rpx 5rpx 20rpx;
}

.grid-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.post-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.post-image {
  width: 100%;
  height: 200rpx;
}

.post-info {
  padding: 16rpx;
}

.post-title {
  font-size: 24rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.post-time {
  font-size: 20rpx;
  color: #999999;
}

.like-info {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.like-icon {
  width: 16rpx;
  height: 16rpx;
}

.like-count {
  font-size: 20rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 16rpx;
  display: block;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}

/* 操作弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.options-modal {
  width: 100%;
  background: #FFFFFF;
  border-radius: 20rpx 20rpx 0 0;
  padding: 0;
}

.option-item {
  padding: 32rpx;
  text-align: center;
  border-bottom: 1rpx solid #E0E0E0;
}

.option-item:last-child {
  border-bottom: none;
}

.option-text {
  font-size: 32rpx;
  color: #333333;
}

.option-item.delete .option-text {
  color: #FF4444;
}

.option-item.cancel {
  background: #EDEDED;
}