/* 我的帖子页面样式 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

/* 顶部分栏 */
.tab-bar {
  display: flex;
  align-items: center;
  height: 92rpx;
  padding: 0 56rpx;
  border-bottom: 1rpx solid #F2F2F2;
  background: #FFFFFF;
  box-sizing: border-box;
}

.tab-item {
  flex: 1;
  height: 92rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #111111;
  font-weight: 700;
}

.tab-line {
  position: absolute;
  bottom: 12rpx;
  width: 36rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: transparent;
}

.tab-item.active .tab-line {
  background: #111111;
}

/* 帖子列表 */
.post-list {
  flex: 1;
  padding: 16rpx 12rpx 28rpx;
  box-sizing: border-box;
}

.grid-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.post-card {
  background: #FFFFFF;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: none;
}

.post-image {
  width: 100%;
  height: 300rpx;
  background: #F6F6F6;
}

.post-info {
  padding: 14rpx 8rpx 18rpx;
}

.post-title {
  font-size: 26rpx;
  color: #222222;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.35;
}

.post-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.post-time {
  font-size: 22rpx;
  color: #999999;
}

.like-info {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.like-icon {
  width: 22rpx;
  height: 22rpx;
}

.like-count {
  font-size: 22rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 16rpx;
  display: block;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}

/* 操作弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.options-modal {
  width: 100%;
  background: #FFFFFF;
  border-radius: 20rpx 20rpx 0 0;
  padding: 0;
}

.option-item {
  padding: 32rpx;
  text-align: center;
  border-bottom: 1rpx solid #E0E0E0;
}

.option-item:last-child {
  border-bottom: none;
}

.option-text {
  font-size: 32rpx;
  color: #333333;
}

.option-item.delete .option-text {
  color: #FF4444;
}

.option-item.cancel {
  background: #EDEDED;
}

/* Visual refresh */
page {
  background: linear-gradient(180deg, #f8faf6 0%, #edf7f2 100%);
}

.container {
  background: transparent;
}

.tab-bar {
  height: 104rpx;
  margin: 20rpx 24rpx 10rpx;
  padding: 0 18rpx;
  border: 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 34rpx rgba(37, 49, 44, 0.08);
}

.tab-item {
  height: 80rpx;
  border-radius: 999rpx;
}

.tab-item.active {
  background: linear-gradient(135deg, #eaf8f1 0%, #edf5ff 100%);
}

.tab-text {
  color: #6d7972;
}

.tab-item.active .tab-text {
  color: #2f9c7d;
}

.tab-line {
  bottom: 8rpx;
  background: transparent;
}

.tab-item.active .tab-line {
  width: 42rpx;
  background: #2f9c7d;
}

.post-list {
  padding: 20rpx 18rpx 150rpx;
}

.grid-container {
  gap: 18rpx;
}

.post-card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 16rpx 36rpx rgba(37, 49, 44, 0.08);
  animation: fadeUp 520ms ease both;
}

.post-card:active {
  transform: scale(0.98);
}

.post-image {
  height: 310rpx;
  background: #edf3ef;
}

.post-info {
  padding: 16rpx 14rpx 18rpx;
}

.post-title {
  color: #26312c;
  font-weight: 800;
}

.post-time,
.like-count,
.empty-text,
.empty-hint {
  color: #7f8c85;
}

.modal {
  background: rgba(24, 34, 30, 0.48);
}

.options-modal {
  border-radius: 34rpx 34rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -18rpx 44rpx rgba(37, 49, 44, 0.14);
}

.option-item {
  border-bottom-color: rgba(38, 49, 44, 0.08);
}

.option-item.cancel {
  background: #f2f7f4;
}
