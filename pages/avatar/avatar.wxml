<view class="container">
  <view class="header">
    <text class="title">我的数字分身库</text>
    <text class="subtitle">点击照片设为当前试穿模特，点击 ✖ 可删除</text>
  </view>

  <view class="avatar-grid">
    <block wx:for="{{avatarList}}" wx:key="*this">
      <view class="avatar-item {{currentAvatar === item ? 'active' : ''}}" bindtap="setDefaultAvatar" data-url="{{item}}">
        <image class="avatar-img" src="{{item}}" mode="aspectFill"></image>
        
        <view class="current-badge" wx:if="{{currentAvatar === item}}">使用中</view>
        
        <view class="delete-btn" catchtap="deleteAvatar" data-url="{{item}}">✕</view>
      </view>
    </block>

    <view class="avatar-item upload-box" bindtap="uploadNewAvatar">
      <view class="plus-icon">+</view>
      <text class="upload-text">添加新形象</text>
    </view>
  </view>
</view>