page {
  background-color: #f8f9fa;
}

.container {
  padding: 40rpx;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #888;
}

/* 网格布局：一行两列 */
.avatar-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.avatar-item {
  width: 48%;
  height: 400rpx;
  border-radius: 20rpx;
  background: #fff;
  margin-bottom: 30rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  overflow: hidden;
  border: 4rpx solid transparent;
  transition: all 0.2s ease;
}

/* 选中状态的边框高亮 */
.avatar-item.active {
  border-color: #07c160;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.2);
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* 使用中标签 */
.current-badge {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background: rgba(7, 193, 96, 0.9);
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  padding: 8rpx 0;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 上传新形象按钮 */
.upload-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ccc;
  background: #fafafa;
}

.plus-icon {
  font-size: 80rpx;
  color: #ccc;
  margin-bottom: 20rpx;
  line-height: 1;
}

.upload-text {
  font-size: 28rpx;
  color: #999;
}

/* Visual refresh */
page {
  background: linear-gradient(180deg, #f8faf6 0%, #edf7f2 100%);
}

.container {
  padding: 36rpx 24rpx 58rpx;
}

.header {
  margin-bottom: 34rpx;
  animation: fadeUp 520ms ease both;
}

.title {
  color: #26312c;
  font-size: 42rpx;
  font-weight: 900;
}

.subtitle {
  color: #718078;
}

.avatar-grid {
  gap: 0;
}

.avatar-item {
  height: 410rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 4rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 18rpx 40rpx rgba(37, 49, 44, 0.08);
  animation: fadeUp 520ms 80ms ease both;
}

.avatar-item:active {
  transform: scale(0.97);
}

.avatar-item.active {
  border-color: #2f9c7d;
  box-shadow: 0 20rpx 42rpx rgba(47, 156, 125, 0.22);
}

.current-badge {
  background: linear-gradient(135deg, rgba(47, 156, 125, 0.94) 0%, rgba(111, 183, 255, 0.94) 100%);
  font-weight: 800;
}

.delete-btn {
  background: rgba(38, 49, 44, 0.58);
}

.upload-box {
  border: 2rpx dashed rgba(47, 156, 125, 0.28);
  background: rgba(255, 255, 255, 0.7);
}

.plus-icon {
  color: #2f9c7d;
}

.upload-text {
  color: #6d7972;
  font-weight: 700;
}
