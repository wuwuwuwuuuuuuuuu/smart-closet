page {
  background-color: #f8f9fa;
}

.container {
  padding: 40rpx;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #888;
}

/* 网格布局：一行两列 */
.avatar-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.avatar-item {
  width: 48%;
  height: 400rpx;
  border-radius: 20rpx;
  background: #fff;
  margin-bottom: 30rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  overflow: hidden;
  border: 4rpx solid transparent;
  transition: all 0.2s ease;
}

/* 选中状态的边框高亮 */
.avatar-item.active {
  border-color: #07c160;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.2);
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* 使用中标签 */
.current-badge {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background: rgba(7, 193, 96, 0.9);
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  padding: 8rpx 0;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 上传新形象按钮 */
.upload-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ccc;
  background: #fafafa;
}

.plus-icon {
  font-size: 80rpx;
  color: #ccc;
  margin-bottom: 20rpx;
  line-height: 1;
}

.upload-text {
  font-size: 28rpx;
  color: #999;
}