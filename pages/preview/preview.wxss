page { background-color: #1a1a1a; }

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.main-image-wrap {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
  overflow: hidden;
}

.main-image {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.3);
}

.bottom-panel {
  background-color: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 30rpx 60rpx;
  box-shadow: 0 -10rpx 30rpx rgba(0,0,0,0.1);
}

.panel-header {
  font-size: 32rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 40rpx;
  text-align: center; 
}

.scene-actions {
  display: flex;
  justify-content: center;
  gap: 80rpx; 
  margin-bottom: 50rpx;
}

.scene-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-box {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx; 
  background-color: #f5f5f5;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 2rpx dashed #ccc;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.icon-box:active { transform: scale(0.95); }

.highlight-box {
  background: linear-gradient(135deg, #e0f2fe, #bae6fd);
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(3, 105, 161, 0.15);
}

.icon-text { font-size: 28rpx; color: #666; font-weight: bold; }
.highlight-box .icon-text { color: #0369a1; }
.scene-name { font-size: 26rpx; color: #666; font-weight: 500; }

/* 🌟 新版三个按钮排版 */
.btn-group {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}
.btn {
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50rpx;
  font-size: 28rpx;
  height: 80rpx;
  font-weight: bold;
}
.btn-cancel { flex: 1; background: #f0f0f0; color: #666; }
.btn-star { flex: 1.2; background: #fffcf8; color: #f59e0b; border: 2rpx solid #f59e0b; box-sizing: border-box; }
.btn-star.collected { background: #f59e0b; color: #fff; }
.btn-primary { flex: 1.5; background: #2F9C7D; color: #fff; }

/* 弹窗样式 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6); display: flex; justify-content: center; align-items: center; z-index: 999;
}
.modal-content { background: #fff; width: 80%; border-radius: 30rpx; padding: 40rpx; box-sizing: border-box; }
.modal-title { font-size: 32rpx; font-weight: bold; margin-bottom: 30rpx; text-align: center; }
.prompt-input {
  width: 100%; height: 200rpx; background: #f9f9f9; padding: 20rpx; border-radius: 16rpx;
  font-size: 28rpx; box-sizing: border-box; margin-bottom: 30rpx;
}
.modal-btns { display: flex; justify-content: space-between; border-top: 1px solid #eee; padding-top: 20rpx; }
.modal-btn { width: 48%; text-align: center; padding: 20rpx 0; font-size: 30rpx; border-radius: 16rpx; }
.modal-btn.cancel { background: #f5f5f5; color: #666; }
.modal-btn.confirm { background: #2F9C7D; color: #fff; }

/* Visual refresh */
page {
  background: #17201c;
}

.main-image-wrap {
  padding: 34rpx;
  background: linear-gradient(180deg, #17201c 0%, #26312c 100%);
}

.main-image {
  border-radius: 34rpx;
  box-shadow: 0 24rpx 56rpx rgba(0, 0, 0, 0.38);
}

.bottom-panel {
  border-radius: 42rpx 42rpx 0 0;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -18rpx 44rpx rgba(0, 0, 0, 0.22);
}

.panel-header {
  color: #26312c;
  font-weight: 900;
}

.icon-box {
  border: 0;
  border-radius: 30rpx;
  background: #f1f7f3;
  box-shadow: inset 0 0 0 1rpx rgba(47, 156, 125, 0.12);
}

.highlight-box {
  background: linear-gradient(135deg, #eaf8f1 0%, #edf5ff 100%);
  box-shadow: 0 12rpx 24rpx rgba(47, 156, 125, 0.14);
}

.highlight-box .icon-text {
  color: #2f9c7d;
}

.btn {
  border-radius: 999rpx;
}

.btn-cancel {
  background: #f2f7f4;
}

.btn-star {
  background: #fff7ea;
  color: #f2a51a;
  border-color: #f2a51a;
}

.btn-star.collected {
  background: #f2a51a;
}

.btn-primary,
.modal-btn.confirm {
  background: linear-gradient(135deg, #2f9c7d 0%, #6fb7ff 100%);
  box-shadow: 0 12rpx 24rpx rgba(47, 156, 125, 0.2);
}

.modal-mask {
  background: rgba(20, 31, 27, 0.62);
}

.modal-content {
  border-radius: 32rpx;
}

.prompt-input {
  border-radius: 24rpx;
  background: #f4f8f5;
}
