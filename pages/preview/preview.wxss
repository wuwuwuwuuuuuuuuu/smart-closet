page { background-color: #1a1a1a; }

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.main-image-wrap {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
  overflow: hidden;
}

.main-image {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.3);
}

.bottom-panel {
  background-color: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 30rpx 60rpx;
  box-shadow: 0 -10rpx 30rpx rgba(0,0,0,0.1);
}

.panel-header {
  font-size: 32rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 40rpx;
  text-align: center; /* 标题居中 */
}

/* 🌟 全新居中布局 */
.scene-actions {
  display: flex;
  justify-content: center;
  gap: 80rpx; /* 两个按钮之间的间距 */
  margin-bottom: 50rpx;
}

.scene-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-box {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx; /* 更圆润的图标 */
  background-color: #f5f5f5;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 2rpx dashed #ccc;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.icon-box:active {
  transform: scale(0.95);
}

.highlight-box {
  background: linear-gradient(135deg, #e0f2fe, #bae6fd);
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(3, 105, 161, 0.15);
}

.icon-text { font-size: 28rpx; color: #666; font-weight: bold; }
.highlight-box .icon-text { color: #0369a1; }
.scene-name { font-size: 26rpx; color: #666; font-weight: 500; }

.btn-group {
  display: flex;
  justify-content: space-between;
}
.btn-cancel { width: 30%; border-radius: 50rpx; font-size: 28rpx; background: #f0f0f0; color: #666; }
.btn-primary { width: 65%; border-radius: 50rpx; font-size: 28rpx; background: #2F9C7D; color: #fff; }

/* 弹窗样式 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6); display: flex; justify-content: center; align-items: center; z-index: 999;
}
.modal-content { background: #fff; width: 80%; border-radius: 30rpx; padding: 40rpx; box-sizing: border-box; }
.modal-title { font-size: 32rpx; font-weight: bold; margin-bottom: 30rpx; text-align: center; }
.prompt-input {
  width: 100%; height: 200rpx; background: #f9f9f9; padding: 20rpx; border-radius: 16rpx;
  font-size: 28rpx; box-sizing: border-box; margin-bottom: 30rpx;
}
.modal-btns { display: flex; justify-content: space-between; border-top: 1px solid #eee; padding-top: 20rpx; }
.modal-btn { width: 48%; text-align: center; padding: 20rpx 0; font-size: 30rpx; border-radius: 16rpx; }
.modal-btn.cancel { background: #f5f5f5; color: #666; }
.modal-btn.confirm { background: #2F9C7D; color: #fff; }