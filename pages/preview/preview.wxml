<view class="container">
  <view class="main-image-wrap">
    <image src="{{displayImage}}" mode="aspectFit" class="main-image" show-menu-by-longpress="true"></image>
  </view>

  <view class="bottom-panel">
    <view class="panel-header">一键场景穿越</view>
    
    <view class="scene-actions">
      <view class="scene-item" bindtap="chooseLocalBackground">
        <view class="icon-box"><text class="icon-text">相册</text></view>
        <text class="scene-name">传图</text>
      </view>

      <view class="scene-item" bindtap="openPromptModal">
        <view class="icon-box highlight-box"><text class="icon-text">AI</text></view>
        <text class="scene-name">文字</text>
      </view>
    </view>

    <view class="btn-group">
      <button class="btn-cancel" bindtap="goBack">返回重选</button>
      <button class="btn-primary" bindtap="saveToAlbum" loading="{{isSaving}}" disabled="{{isFusing || isSaving}}">保存到相册</button>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showPromptModal}}">
    <view class="modal-content">
      <view class="modal-title">描述你想要的场景</view>
      <textarea class="prompt-input" bindinput="onPromptInput" placeholder="例如：极简高级灰纯色背景，影棚打光..." value="{{promptText}}" cursor-spacing="20"></textarea>
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="closePromptModal">取消</view>
        <view class="modal-btn confirm" bindtap="generateByPrompt">AI 穿越</view>
      </view>
    </view>
  </view>

  <canvas type="2d" id="compCanvas" style="width:750rpx; height:1334rpx; position:absolute; left:-10000px; top:-10000px;"></canvas>
</view>