<view class="container">
  <view class="nav-bar">
    <view class="nav-left" bindtap="goBack">
      <image src="cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img10.png" class="nav-icon" />
    </view>
    <view class="nav-right" bindtap="showBackgroundOptions">
      <image src="cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img11.png" class="nav-icon" />
    </view>
  </view>

  <view class="preview-area">
    <view class="preview-container">
      <image 
        src="{{currentBackground}}" 
        class="background-image" 
        mode="aspectFill" />
      
      <view class="tryon-display" wx:if="{{transparentImage || tryonImage}}">
        <image src="{{transparentImage || tryonImage}}" class="tryon-image" mode="aspectFit" />
      </view>
      
      <view class="no-tryon-section" wx:if="{{!transparentImage && !tryonImage}}">
        <view class="no-tryon-icon">👕</view>
        <text class="no-tryon-text">暂无试穿照片</text>
      </view>
    </view>
  </view>

  <view class="action-btn-group" style="position: fixed; right: 30rpx; bottom: 60rpx; display: flex; flex-direction: column; gap: 30rpx; z-index: 100;">
    <view class="generate-btn" bindtap="saveToHistory" style="position: relative; right: 0; bottom: 0;">
      <image src="cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img12.png" class="generate-icon" />
      <text class="generate-text">保存穿搭</text>
    </view>
    
    <view class="generate-btn" bindtap="generatePoster" style="position: relative; right: 0; bottom: 0;">
      <image src="cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img12.png" class="generate-icon" />
      <text class="generate-text">生成海报</text>
    </view>
  </view>

  <view class="modal {{showBackgroundModal ? 'show' : ''}}" bindtap="hideBackgroundModal">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">选择背景</text>
        <view class="modal-close" bindtap="hideBackgroundModal">×</view>
      </view>
      
      <view class="background-options">
        <view 
          class="background-item {{currentBackground === item.image ? 'active' : ''}}" 
          wx:for="{{backgroundOptions}}" 
          wx:key="id"
          bindtap="selectBackground"
          data-background="{{item.image}}">
          <image src="{{item.image}}" class="background-thumb" mode="aspectFill" />
          <text class="background-name">{{item.name}}</text>
        </view>
      </view>
      
      <view class="modal-actions">
        <view class="btn btn-secondary" bindtap="chooseLocalBackground">导入本地图片</view>
        <view class="btn btn-primary" bindtap="confirmBackground">确定</view>
      </view>
    </view>
  </view>

  <canvas type="2d" id="compCanvas" style="position: absolute; left: -9999px; width: 750px; height: 1334px;"></canvas>

</view>