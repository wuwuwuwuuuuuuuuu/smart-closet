page {
  background: linear-gradient(180deg, #f7faf6 0%, #edf6f2 100%);
}

.page-container {
  width: 100%;
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.header-bg {
  width: 100%;
  height: 520rpx;
  position: relative;
  overflow: hidden;
}

.bg-img {
  width: 100%;
  height: 100%;
  transform: scale(1.02);
}

.bg-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(20, 31, 27, 0.05) 0%, rgba(20, 31, 27, 0.68) 100%);
}

.change-bg-tip {
  position: absolute;
  right: 28rpx;
  top: 96rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.94);
  font-size: 22rpx;
  background: rgba(20, 31, 27, 0.34);
  backdrop-filter: blur(10px);
}

.main-content {
  position: relative;
  z-index: 10;
  margin-top: -170rpx;
  padding: 0 26rpx 54rpx;
}

.user-header {
  min-height: 164rpx;
  margin-bottom: 30rpx;
  padding: 18rpx 10rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  animation: fadeUp 520ms ease both;
}

.avatar-container {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 32rpx rgba(20, 31, 27, 0.24);
  transition: transform 180ms ease;
}

.avatar-container:active {
  transform: scale(0.96);
}

.user-avatar {
  width: 100%;
  height: 100%;
  background: #eef3ef;
}

.user-details {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.user-name {
  margin-bottom: 10rpx;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
  text-shadow: 0 5rpx 16rpx rgba(20, 31, 27, 0.3);
}

.user-desc {
  color: rgba(255, 255, 255, 0.86);
  font-size: 25rpx;
  line-height: 1.5;
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 26rpx;
  animation: fadeUp 560ms 80ms ease both;
}

.function-item {
  min-height: 150rpx;
  padding: 24rpx 10rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 16rpx 34rpx rgba(37, 49, 44, 0.08);
  transition: transform 180ms ease, box-shadow 180ms ease;
}

.function-item:active {
  transform: translateY(4rpx) scale(0.97);
  box-shadow: 0 8rpx 18rpx rgba(37, 49, 44, 0.07);
}

.function-icon {
  width: 66rpx;
  height: 66rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e7f7f0 0%, #edf5ff 100%);
}

.icon-img {
  width: 42rpx;
  height: 42rpx;
}

.function-text {
  color: #3b4741;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.25;
}

.settings-section {
  overflow: hidden;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 18rpx 40rpx rgba(37, 49, 44, 0.08);
  animation: fadeUp 560ms 160ms ease both;
}

.setting-item {
  min-height: 96rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(38, 49, 44, 0.06);
  transition: background 160ms ease, transform 160ms ease;
}

.setting-item:last-child {
  border-bottom: 0;
}

.setting-item:active {
  background: #f2f7f4;
  transform: scale(0.99);
}

.setting-text {
  color: #26312c;
  font-size: 28rpx;
  font-weight: 700;
}

.arrow {
  color: #9aa59f;
  font-family: consolas, sans-serif;
  font-size: 30rpx;
  font-weight: 300;
}
