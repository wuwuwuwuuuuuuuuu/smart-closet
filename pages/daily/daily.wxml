<view class="page-container">
  <view class="hero-section">
    <view class="hero-frame">
      <image class="hero-image" src="{{heroImage}}" mode="widthFix" />
    </view>
  </view>

  <scroll-view class="content-scroll" scroll-y="true" enable-flex="true">
    <view class="weather-card">
      <view class="weather-top">
        <view class="weather-main">
          <text class="weather-icon">{{weatherInfo.icon}}</text>
          <view class="weather-values">
            <text class="temperature">{{weatherInfo.temp}}</text>
            <text class="weather-text">{{weatherInfo.text}}</text>
          </view>
        </view>
        <view class="weather-meta">
          <text class="city-name">{{currentCity}}</text>
          <text class="date-label">{{currentDateLabel}}</text>
          <view class="location-actions">
            <text class="location-action" bindtap="refreshLocation">重新定位</text>
            <text class="location-action secondary" bindtap="selectCity">切换城市</text>
          </view>
        </view>
      </view>
      <view class="weather-divider"></view>
      <view class="weather-bottom">
        <text class="section-title">天气提醒</text>
        <text class="weather-suggestion">{{weatherSuggestion}}</text>
        <view class="debug-actions">
          <text class="debug-action {{isRebuildingKnowledge ? 'debug-action-disabled' : ''}}" bindtap="triggerKnowledgeRebuild">
            {{isRebuildingKnowledge ? '补同步处理中...' : '补同步/查状态'}}
          </text>
          <text class="debug-action debug-action-secondary {{isRebuildingKnowledge ? 'debug-action-disabled' : ''}}" bindtap="triggerKnowledgeForceResync">
            {{isRebuildingKnowledge ? '强制重同步处理中...' : '强制全量重同步'}}
          </text>
        </view>
        <text class="debug-summary" wx:if="{{knowledgeRebuildSummary}}">{{knowledgeRebuildSummary}}</text>
      </view>
    </view>

    <view class="chat-section">
      <view class="chat-header">
        <text class="chat-title">智能推荐对话</text>
        <text class="chat-subtitle">告诉我场景、风格或颜色偏好，我来帮你整理搭配建议。</text>
      </view>

      <view class="conversation-list">
        <block wx:for="{{conversationList}}" wx:key="id">
          <view class="message-row {{item.role === 'user' ? 'user-row' : 'assistant-row'}}">
            <view class="message-bubble user-bubble" wx:if="{{item.role === 'user'}}">
              <text class="message-text">{{item.text}}</text>
            </view>

            <view class="assistant-result-card" wx:if="{{item.role === 'assistant' && item.type === 'result-card'}}">
              <text class="result-summary">{{item.data.replyText}}</text>

              <view class="result-lines" wx:if="{{item.data.outfitLines.length}}">
                <text class="result-line" wx:for="{{item.data.outfitLines}}" wx:key="*this">{{item}}</text>
              </view>

              <view class="result-tips" wx:if="{{item.data.tips.length}}">
                <text class="tip-line" wx:for="{{item.data.tips}}" wx:key="*this">{{item}}</text>
              </view>

              <text class="retrieval-source" wx:if="{{item.data.retrievalSource}}">
                来源：{{item.data.retrievalSource}} · 命中 {{item.data.retrievalHitCount}} 件
              </text>

              <view class="cta-row" bindtap="goToTryOnFromRecommendation">
                <text class="cta-text">{{item.data.ctaLabel}}</text>
                <view class="cta-arrow-circle">
                  <text class="cta-arrow-text">›</text>
                </view>
              </view>
            </view>
          </view>
        </block>

        <view class="empty-state" wx:if="{{!conversationList.length}}">
          <text class="empty-title">还没有开始对话</text>
          <text class="empty-text">例如：今天 25 度要上班、想要温柔一点；或者：周末逛街想穿得清爽一点。</text>
        </view>

        <view class="loading-row" wx:if="{{isRecommendationLoading}}">
          <view class="loading-card">
            <text class="loading-text">正在生成推荐，请稍等...</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="composer-bar">
    <view class="composer-panel">
      <input
        class="composer-input"
        placeholder="输入今天的穿搭需求，例如：通勤、约会、下雨天"
        confirm-type="send"
        value="{{pendingUserInput}}"
        bindinput="onRecommendationInput"
        bindconfirm="submitRecommendationRequest"
      />
      <view class="send-btn {{isRecommendationLoading ? 'send-btn-disabled' : ''}}" bindtap="submitRecommendationRequest">
        <text class="send-text">{{isRecommendationLoading ? '生成中' : '发送'}}</text>
      </view>
    </view>
  </view>
</view>
