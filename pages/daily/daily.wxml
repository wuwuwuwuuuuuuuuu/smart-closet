<view class="page-container">
  <view class="hero-section">
    <image class="hero-image" src="{{heroImage}}" mode="aspectFill" />
  </view>

  <scroll-view class="content-scroll" scroll-y="true" enable-flex="true">
    <view class="weather-card">
      <view class="weather-main-row">
        <view class="weather-text-group">
          <text class="temperature">{{weatherInfo.temp}}</text>
          <text class="weather-type">{{weatherInfo.text}}</text>
        </view>
        <text class="weather-icon">{{weatherInfo.icon}}</text>
      </view>
      <view class="weather-sub-row">
        <text class="city-name">{{currentCity}}</text>
        <text class="date-label">{{currentDateLabel}}</text>
      </view>
      <view class="divider"></view>
      <view class="suggestion-block">
        <text class="suggestion-title">今日天气提醒</text>
        <text class="suggestion-text">{{weatherSuggestion}}</text>
      </view>
    </view>

    <view class="chat-section">
      <block wx:for="{{conversationList}}" wx:key="id">
        <view wx:if="{{item.role === 'user'}}" class="chat-row user-row">
          <view class="user-bubble">{{item.text}}</view>
        </view>

        <view wx:elif="{{item.type === 'result-card'}}" class="chat-row assistant-row">
          <view class="assistant-result-card">
            <text class="result-summary">{{item.data.replyText}}</text>
            <view class="outfit-lines" wx:if="{{item.data.outfitLines.length}}">
              <text wx:for="{{item.data.outfitLines}}" wx:for-item="line" wx:key="*this" class="outfit-line">{{line}}</text>
            </view>
            <view class="tips-list" wx:if="{{item.data.tips.length}}">
              <text wx:for="{{item.data.tips}}" wx:for-item="tip" wx:key="*this" class="tip-text">{{tip}}</text>
            </view>
            <view class="cta-row" bindtap="goToTryOnFromReminder" data-request-id="{{item.data.requestId}}">
              <text class="cta-text">{{item.data.ctaLabel}}</text>
              <image class="cta-arrow" src="{{tryOnArrowIcon}}" mode="aspectFit" />
            </view>
          </view>
        </view>

        <view wx:else class="chat-row assistant-row">
          <view class="assistant-bubble">{{item.text}}</view>
        </view>
      </block>

      <view wx:if="{{isReminderLoading}}" class="assistant-loading">
        正在生成搭配建议...
      </view>
    </view>
  </scroll-view>

  <view class="composer-bar">
    <textarea
      class="composer-input"
      value="{{pendingUserInput}}"
      placeholder="今天想试试什么风格呢？"
      maxlength="120"
      auto-height="true"
      bindinput="onReminderInput"
      confirm-type="send"
    />
    <view class="send-btn {{pendingUserInput ? '' : 'disabled'}}" bindtap="submitReminderRequest">发送</view>
  </view>
</view>
