page {
  height: 100vh;
  background: linear-gradient(180deg, #f8faf6 0%, #edf7f2 52%, #f6f5f0 100%);
}

.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.hero-section {
  flex-shrink: 0;
  padding: 24rpx 24rpx 0;
}

.hero-frame {
  overflow: hidden;
  border-radius: 34rpx;
  background: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 20rpx 46rpx rgba(37, 49, 44, 0.11);
  animation: fadeUp 520ms ease both;
}

.hero-image {
  width: 100%;
  display: block;
}

.content-scroll {
  flex: 1;
  min-height: 0;
  padding: 24rpx;
}

.weather-card,
.chat-section {
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.74);
  box-shadow: 0 16rpx 38rpx rgba(37, 49, 44, 0.08);
}

.weather-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  animation: fadeUp 560ms 80ms ease both;
}

.weather-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 22rpx;
}

.weather-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.weather-icon {
  width: 82rpx;
  height: 82rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ffdfcf 0%, #dff0ff 100%);
  font-size: 52rpx;
  line-height: 1;
}

.weather-values {
  display: flex;
  flex-direction: column;
}

.temperature {
  color: #26312c;
  font-size: 50rpx;
  font-weight: 900;
  line-height: 1.1;
}

.weather-text,
.city-name,
.date-label {
  color: #66736c;
  font-size: 24rpx;
}

.weather-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.location-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 8rpx;
}

.location-action {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2f9c7d 0%, #6fb7ff 100%);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.location-action.secondary {
  color: #59665f;
  background: #eef5f1;
}

.weather-divider {
  height: 1rpx;
  margin: 24rpx 0;
  background: rgba(38, 49, 44, 0.08);
}

.section-title {
  display: block;
  color: #26312c;
  font-size: 28rpx;
  font-weight: 800;
}

.weather-suggestion {
  display: block;
  margin-top: 14rpx;
  color: #4f5d55;
  font-size: 26rpx;
  line-height: 1.7;
}

.debug-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.debug-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  color: #2f9c7d;
  background: #eef8f2;
  font-size: 22rpx;
  line-height: 1.2;
}

.debug-action-disabled {
  opacity: 0.7;
}

.debug-action-secondary {
  color: #d36f50;
  background: #fff1eb;
}

.debug-summary {
  display: block;
  margin-top: 12rpx;
  color: #6d7972;
  font-size: 22rpx;
  line-height: 1.6;
}

.chat-section {
  padding: 28rpx;
  animation: fadeUp 560ms 150ms ease both;
}

.chat-header {
  margin-bottom: 20rpx;
}

.chat-title {
  display: block;
  color: #26312c;
  font-size: 31rpx;
  font-weight: 900;
}

.chat-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #6d7972;
  font-size: 24rpx;
  line-height: 1.6;
}

.conversation-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-bottom: 8rpx;
}

.message-row {
  display: flex;
}

.user-row {
  justify-content: flex-end;
}

.assistant-row {
  justify-content: flex-start;
}

.message-bubble,
.assistant-result-card,
.loading-card,
.empty-state {
  max-width: 100%;
}

.user-bubble {
  max-width: 84%;
  padding: 20rpx 24rpx;
  border-radius: 26rpx 26rpx 8rpx 26rpx;
  background: linear-gradient(135deg, #ff8a72 0%, #2f9c7d 100%);
  box-shadow: 0 12rpx 24rpx rgba(255, 138, 114, 0.18);
}

.message-text {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.6;
}

.assistant-result-card,
.loading-card,
.empty-state {
  width: 100%;
  padding: 24rpx;
  border-radius: 26rpx;
  background: #f3f8f4;
  border: 1rpx solid rgba(47, 156, 125, 0.08);
}

.result-summary,
.empty-title {
  display: block;
  color: #26312c;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.6;
}

.result-lines,
.result-tips {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.result-line,
.tip-line,
.empty-text,
.loading-text {
  color: #5f6d66;
  font-size: 25rpx;
  line-height: 1.6;
}

.retrieval-source {
  display: block;
  margin-top: 12rpx;
  color: #8b9690;
  font-size: 22rpx;
  line-height: 1.5;
}

.cta-row {
  height: 84rpx;
  margin-top: 20rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(37, 49, 44, 0.06);
}

.cta-text {
  color: #26312c;
  font-size: 26rpx;
  font-weight: 800;
}

.cta-arrow-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2f9c7d 0%, #6fb7ff 100%);
}

.cta-arrow-text {
  margin: 0;
  color: #ffffff;
  font-size: 34rpx;
  line-height: 1;
  text-align: center;
  transform: translateY(-2rpx);
}

.composer-bar {
  flex-shrink: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.86);
  backdrop-filter: blur(14px);
}

.composer-panel {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(37, 49, 44, 0.09);
}

.composer-input {
  flex: 1;
  min-width: 0;
  color: #26312c;
  font-size: 28rpx;
}

.send-btn {
  flex-shrink: 0;
  min-width: 122rpx;
  height: 76rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2f9c7d 0%, #6fb7ff 100%);
  box-shadow: 0 12rpx 24rpx rgba(47, 156, 125, 0.2);
}

.send-btn-disabled {
  opacity: 0.68;
}

.send-text {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
}
