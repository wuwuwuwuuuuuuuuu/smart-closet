page {
  height: 100vh;
  background: linear-gradient(180deg, #fff6f2 0%, #f4f8ff 100%);
}

.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.hero-section {
  flex-shrink: 0;
  padding: 24rpx 24rpx 0;
}

.hero-frame {
  overflow: hidden;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(34, 41, 69, 0.08);
  background: #ffffff;
}

.hero-image {
  width: 100%;
  display: block;
}

.content-scroll {
  flex: 1;
  min-height: 0;
  padding: 24rpx;
  box-sizing: border-box;
}

.weather-card,
.chat-section {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(31, 46, 74, 0.08);
}

.weather-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.weather-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.weather-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.weather-icon {
  font-size: 56rpx;
  line-height: 1;
}

.weather-values {
  display: flex;
  flex-direction: column;
}

.temperature {
  font-size: 50rpx;
  font-weight: 700;
  color: #1f2e4a;
  line-height: 1.1;
}

.weather-text,
.city-name,
.date-label {
  color: #5d6b85;
  font-size: 24rpx;
}

.weather-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.location-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.location-action {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  color: #ffffff;
  background: linear-gradient(135deg, #ff9f8f 0%, #7ca8ff 100%);
}

.location-action.secondary {
  color: #5d6b85;
  background: #eef3ff;
}

.weather-divider {
  height: 1rpx;
  background: rgba(31, 46, 74, 0.08);
  margin: 24rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2e4a;
}

.weather-suggestion {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #44516b;
}

.debug-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.debug-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #eef3ff;
  color: #4a5fc1;
  font-size: 22rpx;
  line-height: 1.2;
}

.debug-action-disabled {
  opacity: 0.7;
}

.debug-action-secondary {
  background: #fff3ef;
  color: #d16445;
}

.debug-summary {
  display: block;
  margin-top: 12rpx;
  color: #5c6983;
  font-size: 22rpx;
  line-height: 1.6;
}

.chat-section {
  padding: 28rpx;
}

.chat-header {
  margin-bottom: 20rpx;
}

.chat-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2e4a;
}

.chat-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #6c7892;
  font-size: 24rpx;
  line-height: 1.6;
}

.conversation-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-bottom: 8rpx;
}

.message-row {
  display: flex;
}

.user-row {
  justify-content: flex-end;
}

.assistant-row {
  justify-content: flex-start;
}

.message-bubble,
.assistant-result-card,
.loading-card,
.empty-state {
  max-width: 100%;
}

.user-bubble {
  max-width: 84%;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #ff9f8f 0%, #ffb48c 100%);
  border-radius: 24rpx 24rpx 8rpx 24rpx;
  box-shadow: 0 10rpx 20rpx rgba(255, 159, 143, 0.22);
}

.message-text {
  color: #fff;
  font-size: 28rpx;
  line-height: 1.6;
}

.assistant-result-card,
.loading-card,
.empty-state {
  width: 100%;
  padding: 24rpx;
  background: #f7f9ff;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.result-summary,
.empty-title {
  display: block;
  color: #1f2e4a;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.6;
}

.result-lines,
.result-tips {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.result-line,
.tip-line,
.empty-text,
.loading-text {
  color: #5c6983;
  font-size: 25rpx;
  line-height: 1.6;
}

.cta-row {
  margin-top: 20rpx;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cta-text {
  color: #1f2e4a;
  font-size: 26rpx;
  font-weight: 600;
}

.cta-arrow-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9f8f 0%, #7ca8ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cta-arrow-text {
  color: #ffffff;
  font-size: 34rpx;
  line-height: 1;
  margin: 0;
  text-align: center;
  transform: translateY(-2rpx);
}

.composer-bar {
  flex-shrink: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(12px);
}

.composer-panel {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(31, 46, 74, 0.08);
}

.composer-input {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #1f2e4a;
}

.send-btn {
  flex-shrink: 0;
  min-width: 120rpx;
  height: 76rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #ff9f8f 0%, #7ca8ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn-disabled {
  opacity: 0.7;
}

.send-text {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}