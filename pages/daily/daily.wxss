page {
  height: 100vh;
  background: linear-gradient(180deg, #fff4f4 0%, #eef7ff 100%);
}

.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #fff4f4 0%, #eef7ff 100%);
}

.hero-section {
  flex-shrink: 0;
  padding: 24rpx 24rpx 12rpx;
}

.hero-image {
  width: 100%;
  height: 360rpx;
  border-radius: 28rpx;
  display: block;
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.08);
}

.content-scroll {
  flex: 1;
  min-height: 0;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.weather-card,
.assistant-result-card,
.assistant-bubble,
.user-bubble {
  border-radius: 28rpx;
  box-shadow: 0 14rpx 28rpx rgba(17, 17, 17, 0.08);
}

.weather-card {
  background: rgba(255, 255, 255, 0.9);
  padding: 30rpx;
  border: 2rpx solid rgba(17, 17, 17, 0.06);
}

.weather-main-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.weather-text-group {
  display: flex;
  align-items: baseline;
  gap: 18rpx;
}

.temperature {
  font-size: 54rpx;
  font-weight: 700;
  color: #1f2937;
}

.weather-type,
.weather-icon {
  font-size: 30rpx;
  color: #334155;
}

.weather-sub-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 14rpx;
  color: #64748b;
  font-size: 24rpx;
}

.divider {
  margin: 24rpx 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(64, 180, 229, 0.8) 50%, transparent 100%);
}

.suggestion-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2563eb;
  margin-bottom: 12rpx;
}

.suggestion-text {
  font-size: 28rpx;
  line-height: 1.65;
  color: #334155;
}

.chat-section {
  padding: 28rpx 0 32rpx;
}

.chat-row {
  display: flex;
  margin-bottom: 22rpx;
}

.user-row {
  justify-content: flex-end;
}

.assistant-row {
  justify-content: flex-start;
}

.user-bubble,
.assistant-bubble {
  max-width: 82%;
  padding: 22rpx 26rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.user-bubble {
  background: linear-gradient(135deg, #f6d7dd 0%, #e6f0ff 100%);
  color: #111827;
}

.assistant-bubble {
  background: #ffffff;
  color: #334155;
}

.assistant-result-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.96);
  padding: 28rpx;
  border: 2rpx solid rgba(17, 17, 17, 0.08);
}

.result-summary {
  display: block;
  font-size: 30rpx;
  line-height: 1.6;
  color: #111827;
  font-weight: 600;
}

.outfit-lines,
.tips-list {
  margin-top: 18rpx;
}

.outfit-line,
.tip-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.7;
  color: #334155;
}

.cta-row {
  margin-top: 24rpx;
  border: 2rpx solid rgba(17, 17, 17, 0.12);
  border-radius: 22rpx;
  padding: 18rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #ffffff 0%, #f5f7fb 100%);
}

.cta-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.cta-arrow {
  width: 52rpx;
  height: 52rpx;
  transform: scaleX(-1);
}

.assistant-loading {
  margin-top: 12rpx;
  padding: 18rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #64748b;
  font-size: 26rpx;
}

.composer-bar {
  flex-shrink: 0;
  display: flex;
  gap: 16rpx;
  align-items: flex-end;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  border-top: 1rpx solid rgba(17, 17, 17, 0.06);
  box-shadow: 0 -10rpx 30rpx rgba(17, 17, 17, 0.04);
}

.composer-input {
  flex: 1;
  min-height: 84rpx;
  max-height: 220rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.5;
  border: 2rpx solid rgba(17, 17, 17, 0.08);
}

.send-btn {
  width: 120rpx;
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f6d7dd 0%, #dce9ff 100%);
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.send-btn.disabled {
  opacity: 0.55;
}
