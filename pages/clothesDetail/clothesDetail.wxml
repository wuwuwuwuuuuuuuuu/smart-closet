<view class="container" wx:if="{{info}}">
  
  <view class="detail-card">
    <image 
      wx:if="{{info.image}}" 
      src="{{info.image}}" 
      class="main-image" 
      mode="widthFix" 
    />
    <view class="image-error" wx:else>
      <text>图片路径无效或已过期</text>
    </view>
  </view>

  <view class="info-section">
    <view class="title-row">
      <view class="name-box">
        <text class="clothes-name">{{info.name}}</text>
        <text class="category-tag">{{info.category}}</text>
      </view>
    </view>

    <view class="detail-list">
      <view class="detail-item">
        <text class="label">适用季节</text>
        <text class="value">{{info.season}}</text>
      </view>
      <view class="detail-item">
        <text class="label">材质成分</text>
        <text class="value">{{info.material || '未填写'}}</text>
      </view>
      <view class="detail-item" wx:if="{{info.brand}}">
        <text class="label">所属品牌</text>
        <text class="value">{{info.brand}}</text>
      </view>
    </view>

    <view class="tags-header" wx:if="{{info.tags.length > 0}}">衣物标签</view>
    <view class="tags-container" wx:if="{{info.tags.length > 0}}">
      <view class="tag" wx:for="{{info.tags}}" wx:key="*this"># {{item}}</view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="delete-btn" bindtap="confirmDelete">
      <image src="/images/icons/delete.png" class="btn-icon" />
      <text>从我的衣橱移除</text>
    </view>
  </view>

</view> <view class="loading-state" wx:if="{{!info}}">
  <text>正在召唤衣物详情...</text>
</view>