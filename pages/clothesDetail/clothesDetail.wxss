page {
  background-color: #f7f7f7;
  padding-bottom: 120rpx;
}

.container {
  display: flex;
  flex-direction: column;
}

.detail-card {
  width: 100%;
  background: #fff;
  overflow: hidden;
}

.main-image {
  width: 100%;
  display: block;
}

.info-section {
  padding: 30rpx;
  background: #fff;
  margin-top: 20rpx;
}

.title-row {
  margin-bottom: 40rpx;
}

.clothes-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.category-tag {
  font-size: 24rpx;
  background: #e1f5fe;
  color: #03a9f4;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 20rpx;
}

.detail-list {
  border-top: 1rpx solid #eee;
  padding-top: 30rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.label {
  color: #888;
  font-size: 28rpx;
}

.value {
  color: #333;
  font-size: 28rpx;
  font-weight: 500;
}

/* ================= 🌟 标签模块样式 ================= */
.tags-header-wrap {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 40rpx;
  margin-bottom: 20rpx;
}

.tags-header {
  font-size: 26rpx;
  color: #888;
}

.edit-btn {
  font-size: 24rpx;
  color: #03a9f4;
  background: #f0f9ff;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  background: #f0f0f0;
  color: #666;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.no-tags {
  font-size: 26rpx;
  color: #bbb;
  padding: 10rpx 0;
}

/* 编辑模式下的标签特殊样式 */
.tag.edit-mode {
  background: #e1f5fe;
  color: #03a9f4;
}

.delete-icon {
  margin-left: 12rpx;
  font-size: 32rpx;
  color: #ff4d4f;
  line-height: 1;
  font-weight: 300;
}

/* 添加标签输入区 */
.add-tag-box {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  margin-bottom: 30rpx;
}

.tag-input {
  flex: 1;
  background: #f5f7f9;
  height: 72rpx;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}

.add-btn {
  background: #333;
  color: #fff;
  line-height: 72rpx;
  padding: 0 40rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.save-tags-btn {
  background: #07c160;
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  width: 90% !important;
  margin: 10rpx auto 0;
  display: block;
}

/* ================= 底部删除按钮 ================= */
.bottom-bar {
  position: fixed;
  bottom: 0;
  width: 100%;
  height: 110rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  padding-bottom: env(safe-area-inset-bottom);
}

.delete-btn {
  display: flex;
  align-items: center;
  color: #ff4d4f;
  font-size: 30rpx;
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.loading-state {
  text-align: center;
  padding-top: 200rpx;
  color: #999;
}

/* Visual refresh */
page {
  background: linear-gradient(180deg, #f8faf6 0%, #edf7f2 100%);
  padding-bottom: 132rpx;
}

.container {
  gap: 0;
}

.detail-card {
  background: transparent;
}

.main-image {
  border-radius: 0 0 36rpx 36rpx;
  box-shadow: 0 18rpx 42rpx rgba(37, 49, 44, 0.12);
}

.info-section {
  margin: 24rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 18rpx 40rpx rgba(37, 49, 44, 0.08);
  animation: fadeUp 520ms ease both;
}

.clothes-name {
  color: #26312c;
  font-size: 42rpx;
  font-weight: 900;
}

.category-tag,
.edit-btn,
.tag.edit-mode {
  color: #2f9c7d;
  background: #eaf8f1;
}

.detail-list {
  border-top-color: rgba(38, 49, 44, 0.08);
}

.label,
.tags-header,
.no-tags {
  color: #7f8c85;
}

.value {
  color: #26312c;
  font-weight: 700;
}

.tag {
  background: #f0f6f2;
  color: #5f6d66;
}

.tag-input {
  border-radius: 20rpx;
  background: #f7fbf8;
}

.add-btn,
.save-tags-btn {
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2f9c7d 0%, #6fb7ff 100%);
  box-shadow: 0 14rpx 28rpx rgba(47, 156, 125, 0.18);
}

.bottom-bar {
  height: 118rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(14px);
  box-shadow: 0 -12rpx 30rpx rgba(37, 49, 44, 0.08);
}
