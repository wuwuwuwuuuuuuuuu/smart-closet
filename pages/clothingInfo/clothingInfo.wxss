/* 衣物信息录入页面样式 */
.container {
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  min-height: 100vh;
}

/* 顶部导航栏 */
.nav-bar {
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.nav-left {
  display: flex;
  align-items: center;
}

.nav-icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  font-family: PingFang SC;
  text-align: center;
  flex: 1;
}

.save-btn {
  font-size: 28rpx;
  color: #CCCCCC;
  font-weight: 500;
}

.save-btn.active {
  color: #4CAF50;
}

/* 衣物预览区 */
.preview-card {
  background: #EDEDED;
  border-radius: 12rpx;
  padding: 16rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.preview-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.preview-hint {
  font-size: 24rpx;
  color: #999999;
  flex: 1;
}

/* 信息录入表单 */
.form-container {
  margin-bottom: 120rpx;
}

.form-card {
  background: #EDEDED;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  font-weight: 400;
}

.form-picker {
  background: #FFFFFF;
  border-radius: 8rpx;
  padding: 16rpx;
  border: 1rpx solid #E0E0E0;
}

.picker-text {
  font-size: 28rpx;
  color: #333333;
}

.picker-text.placeholder {
  color: #999999;
}

.form-input {
  background: #FFFFFF;
  border-radius: 8rpx;
  padding: 16rpx;
  border: 1rpx solid #E0E0E0;
  font-size: 28rpx;
  color: #333333;
}

/* 材质选项 */
.material-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.material-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.material-tag {
  background: #FFFFFF;
  border: 1rpx solid #E0E0E0;
  border-radius: 20rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  color: #333333;
  transition: all 0.3s ease;
}

.material-tag.selected {
  background: #4CAF50;
  border-color: #4CAF50;
  color: #FFFFFF;
}

.custom-material {
  margin-top: 8rpx;
}

.material-input {
  background: #FFFFFF;
  border-radius: 8rpx;
  padding: 16rpx;
  border: 1rpx solid #E0E0E0;
  font-size: 24rpx;
  color: #333333;
  width: 100%;
  box-sizing: border-box;
}

/* 适用季节标签 */
.season-tags {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.season-tag {
  background: #FFFFFF;
  border: 1rpx solid #E0E0E0;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #333333;
  transition: all 0.3s ease;
}

.season-tag.selected {
  background: #4CAF50;
  border-color: #4CAF50;
  color: #FFFFFF;
}

/* 自定义标签 */
.tag-input-container {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tag-input {
  flex: 1;
  background: #FFFFFF;
  border-radius: 8rpx;
  padding: 16rpx;
  border: 1rpx solid #E0E0E0;
  font-size: 24rpx;
  color: #333333;
}

.add-tag-btn {
  background: #4CAF50;
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  color: #FFFFFF;
  font-size: 24rpx;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.custom-tag {
  background: #E0F7E9;
  border-radius: 16rpx;
  padding: 8rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tag-text {
  font-size: 22rpx;
  color: #4CAF50;
}

.tag-close {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #4CAF50;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 16rpx;
  font-weight: bold;
}

/* 底部操作区 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 20rpx;
  right: 20rpx;
  background: #FFFFFF;
  padding: 24rpx 0 40rpx;
}

.save-action-btn {
  background: #CCCCCC;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
}

.save-action-btn.active {
  background: #4CAF50;
}

.save-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.action-hint {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  display: block;
}