<!-- 发布穿搭页 - 小红书标准重构 -->
<view class="container">
  <!-- 内容区域 -->
  <scroll-view class="content-scroll" scroll-y="true">
    
    <!-- 九宫格图片上传区域 - CSS Grid布局 -->
    <view class="image-grid-section">
      <view class="section-header">
        <text class="section-title">上传穿搭图片</text>
        <text class="image-count">{{imageList.length}}/9</text>
      </view>
      
      <view class="image-grid">
        <!-- 已上传图片 -->
        <view class="grid-item" wx:for="{{imageList}}" wx:key="*this">
          <image src="{{item}}" class="grid-image" mode="aspectFill" />
          <view class="delete-btn" bindtap="deleteImage" data-index="{{index}}">
            <text class="delete-icon">×</text>
          </view>
        </view>
        
        <!-- 上传按钮（未满9张时显示） -->
        <view class="grid-item upload-btn" wx:if="{{imageList.length < 9}}" bindtap="chooseImages">
          <view class="upload-placeholder">
            <text class="add-icon">+</text>
            <text class="upload-text">添加图片</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 标题输入 - 纯净输入区 -->
    <view class="input-section">
      <input 
        class="title-input" 
        placeholder="给穿搭起个吸引人的标题吧" 
        maxlength="50"
        bindinput="onTitleInput"
        value="{{postTitle}}" />
      <text class="char-count">{{postTitle.length}}/50</text>
    </view>

    <!-- 正文输入 - 纯净输入区 -->
    <view class="input-section">
      <textarea 
        class="content-input" 
        placeholder="分享你的穿搭心得、搭配技巧或心情故事..." 
        maxlength="500"
        bindinput="onContentInput"
        show-confirm-bar="{{false}}"
        auto-height
        value="{{postContent}}" />
      <text class="char-count">{{postContent.length}}/500</text>
    </view>

    <!-- 发布按钮 - 小红书红 -->
    <view class="publish-section">
      <view class="publish-btn {{canPublish ? 'active' : ''}}" bindtap="publishPost">
        <text class="publish-text">发布穿搭</text>
      </view>
    </view>
    
  </scroll-view>
</view>