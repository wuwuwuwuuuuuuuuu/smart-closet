/* 发布穿搭页样式 - 小红书标准重构 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

/* 内容区域 */
.content-scroll {
  flex: 1;
}

/* 九宫格图片上传区域 */
.image-grid-section {
  padding: 32rpx;
  background: #FFFFFF;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
}

.image-count {
  font-size: 28rpx;
  color: #999999;
}

/* CSS Grid布局 - 严格按照要求实现 */
.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

/* 图片和上传按钮的外层容器 - 宽高1:1正方形 */
.grid-item {
  width: 100%;
  aspect-ratio: 1/1;
  background: #F7F7F7;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}

.grid-image {
  width: 100%;
  height: 100%;
  display: block;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: bold;
}

.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #E0E0E0;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.add-icon {
  font-size: 48rpx;
  color: #CCCCCC;
  font-weight: 300;
}

.upload-text {
  font-size: 24rpx;
  color: #999999;
}

/* 纯净输入区 - 禁止灰色背景 */
.input-section {
  padding: 0 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #EEEEEE;
  position: relative;
}

.title-input {
  width: 100%;
  height: 100rpx;
  font-size: 32rpx;
  color: #333333;
  background: transparent;
  border: none;
  outline: none;
}

.content-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333333;
  background: transparent;
  border: none;
  outline: none;
  padding: 24rpx 0;
  line-height: 1.6;
}

.char-count {
  position: absolute;
  right: 32rpx;
  bottom: 16rpx;
  font-size: 24rpx;
  color: #CCCCCC;
}

/* 发布按钮 - 小红书红 */
.publish-section {
  padding: 40rpx 32rpx;
}

.publish-btn {
  width: 100%;
  height: 88rpx;
  background: #FF2442;
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.publish-btn.active {
  background: #FF2442;
}

.publish-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .image-grid-section {
    padding: 24rpx;
  }
  
  .input-section {
    padding: 0 24rpx;
  }
}