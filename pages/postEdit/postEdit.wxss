/* 编辑帖子页样式 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E0E0E0;
}

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
}

/* 内容区域 */
.content-scroll {
  flex: 1;
  padding: 0 20rpx;
  height: 100vh;
  box-sizing: border-box;
}

/* 图片区域 */
.image-section {
  margin: 40rpx 0;
}

.image-upload {
  width: 100%;
  height: 500rpx;
  background: #EDEDED;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-sizing: border-box;
  margin: 0;
}

.uploaded-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.add-icon {
  width: 60rpx;
  height: 60rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #999999;
}

/* 输入区域 */
.input-section {
  margin-bottom: 40rpx;
  position: relative;
}

.title-input {
  width: 100%;
  height: 100rpx;
  background: #EDEDED;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  box-sizing: border-box;
  margin: 0;
}

.content-input {
  width: 100%;
  min-height: 300rpx;
  background: #EDEDED;
  border-radius: 16rpx;
  padding: 32rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  box-sizing: border-box;
  margin: 0;
}

.char-count {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  font-size: 24rpx;
  color: #999999;
  background: rgba(255, 255, 255, 0.8);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 发布按钮 */
.publish-section {
  padding: 20rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #E0E0E0;
}

.publish-btn {
  width: 100%;
  height: 80rpx;
  background: #EDEDED;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.publish-btn.active {
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F0FF 100%);
}

.publish-text {
  font-size: 32rpx;
  color: #999999;
  font-weight: 600;
}

.publish-btn.active .publish-text {
  color: #333333;
}