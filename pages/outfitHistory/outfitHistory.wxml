<view class="page">
  <view class="header-card">
    <text class="page-title">历史穿搭</text>
    <picker
      mode="date"
      value="{{selectedDate}}"
      end="{{todayDateKey}}"
      bindchange="onDateChange"
    >
      <view class="date-picker">
        <text>{{selectedDateLabel}}</text>
        <text class="picker-arrow">▼</text>
      </view>
    </picker>

    <view class="available-section" wx:if="{{availableDates.length}}">
      <text class="available-title">有记录的日期</text>
      <scroll-view class="date-scroll" scroll-x enable-flex>
        <view class="date-list">
          <view
            wx:for="{{availableDates}}"
            wx:key="*this"
            class="date-chip {{item === selectedDate ? 'active' : ''}}"
            data-date="{{item}}"
            bindtap="selectAvailableDate"
          >{{dateShortLabels[item]}}</view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-dot"></view>
    <text>正在加载历史穿搭...</text>
  </view>

  <view class="error-state" wx:elif="{{errorMessage}}">
    <text class="state-title">加载失败</text>
    <text class="state-desc">{{errorMessage}}</text>
    <button class="primary-btn compact-btn" bindtap="retryLoad">重新加载</button>
  </view>

  <view class="outfit-list layout-{{records.length}}" wx:elif="{{records.length}}">
    <view
      class="outfit-card {{records.length === 3 && index === 2 ? 'third-card' : ''}}"
      wx:for="{{records}}"
      wx:key="_id"
    >
      <image
        class="outfit-image"
        src="{{item.outfitImageFileID}}"
        mode="widthFix"
        data-record="{{item}}"
        bindtap="onOutfitImageTap"
      />
      <view class="outfit-content">
        <button
          class="save-btn"
          catchtap="saveImage"
          data-record="{{item}}"
          loading="{{savingId === item._id}}"
        >保存图片</button>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <view class="empty-icon-wrap">
      <image class="empty-icon" src="/images/icons/wardrobe.png" mode="aspectFit" />
    </view>
    <text class="state-title">{{isToday ? '今天还没有穿搭记录' : '这一天还没有穿搭记录'}}</text>
    <button wx:if="{{isToday}}" class="primary-btn" bindtap="goToTryOn">去记录今日穿搭</button>
  </view>

</view>
