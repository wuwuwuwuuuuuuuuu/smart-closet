page {
  min-height: 100%;
  background: #EDEDED;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.header-card {
  padding: 30rpx 32rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
}

.page-title {
  display: block;
  margin-bottom: 22rpx;
  color: #333333;
  font-size: 36rpx;
  font-weight: 600;
}

.date-picker {
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #F7F7F7;
  color: #444444;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  color: #999999;
  font-size: 18rpx;
}

.available-section {
  margin-top: 24rpx;
}

.available-title {
  display: block;
  margin-bottom: 14rpx;
  color: #888888;
  font-size: 24rpx;
}

.date-scroll {
  width: 100%;
  white-space: nowrap;
}

.date-list {
  display: inline-flex;
  gap: 14rpx;
}

.date-chip {
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  color: #666666;
  background: #F6F6F6;
  font-size: 24rpx;
}

.date-chip.active {
  color: #C65E82;
  background: #FFF0F5;
  font-weight: 600;
}

.outfit-list {
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 24rpx 20rpx;
}

.outfit-card {
  width: calc(50% - 10rpx);
  min-width: 0;
  overflow: hidden;
  border-radius: 16rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.outfit-list.layout-1 {
  justify-content: center;
}

.outfit-list.layout-1 .outfit-card {
  width: 88%;
  margin-left: auto;
  margin-right: auto;
}

.outfit-card.third-card {
  margin-left: auto;
  margin-right: auto;
}

.outfit-image {
  display: block;
  width: 100%;
  height: auto;
  background: #F5F5F5;
}

.outfit-content {
  padding: 18rpx;
}

.save-btn,
.primary-btn {
  margin: 0;
}

.save-btn {
  width: 100%;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 12rpx;
  border: 1rpx solid #E5E5E5;
  color: #555555;
  background: #FAFAFA;
  font-size: 22rpx;
}

.save-btn::after,
.primary-btn::after {
  border: none;
}

.loading-state,
.error-state,
.empty-state {
  margin-top: 24rpx;
  min-height: 500rpx;
  padding: 70rpx 48rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.loading-state {
  gap: 24rpx;
  color: #888888;
  font-size: 26rpx;
}

.loading-dot {
  width: 34rpx;
  height: 34rpx;
  border: 5rpx solid #F2D8E1;
  border-top-color: #C65E82;
  border-radius: 50%;
  animation: rotate 0.8s linear infinite;
}

@keyframes rotate {
  to {
    transform: rotate(360deg);
  }
}

.empty-icon-wrap {
  width: 132rpx;
  height: 132rpx;
  margin-bottom: 28rpx;
  border-radius: 50%;
  background: #F6F6F6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  width: 72rpx;
  height: 72rpx;
  opacity: 0.65;
}

.state-title {
  color: #333333;
  font-size: 30rpx;
  font-weight: 600;
}

.state-desc {
  margin-top: 16rpx;
  color: #888888;
  font-size: 25rpx;
}

.primary-btn {
  margin-top: 28rpx;
  padding: 0 42rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 38rpx;
  color: #FFFFFF;
  background: #333333;
  font-size: 27rpx;
}

.compact-btn {
  height: 68rpx;
  line-height: 68rpx;
}
