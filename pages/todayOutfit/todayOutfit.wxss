page {
  min-height: 100%;
  background: #EDEDED;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.summary-card {
  min-height: 132rpx;
  padding: 30rpx 32rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.summary-title,
.summary-meta,
.outfit-date {
  display: block;
}

.summary-title {
  color: #333333;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.summary-meta {
  color: #888888;
  font-size: 25rpx;
}

.summary-badge {
  padding: 12rpx 22rpx;
  border-radius: 28rpx;
  color: #C65E82;
  background: #FFF0F5;
  font-size: 25rpx;
  font-weight: 600;
}

.outfit-list {
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
}

.outfit-card {
  width: calc(50% - 10rpx);
  min-width: 0;
  overflow: hidden;
  border-radius: 16rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.outfit-list.count-1 .outfit-card {
  width: 88%;
}

.outfit-image {
  display: block;
  width: 100%;
  height: 360rpx;
  background: #F5F5F5;
}

.outfit-content {
  padding: 18rpx;
}

.card-actions {
  display: flex;
  gap: 10rpx;
}

.action-btn {
  flex: 1;
  min-width: 0;
  margin: 0;
  padding: 0 10rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 12rpx;
  border: 1rpx solid #E5E5E5;
  color: #555555;
  background: #FAFAFA;
  font-size: 22rpx;
}

.action-btn::after,
.primary-btn::after {
  border: none;
}

.danger-btn {
  color: #C84D5D;
  background: #FFF4F5;
  border-color: #FFE0E4;
}

.loading-state,
.error-state,
.empty-state {
  margin-top: 24rpx;
  min-height: 520rpx;
  padding: 70rpx 48rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.loading-state {
  gap: 24rpx;
  color: #888888;
  font-size: 26rpx;
}

.loading-dot {
  width: 34rpx;
  height: 34rpx;
  border: 5rpx solid #F2D8E1;
  border-top-color: #C65E82;
  border-radius: 50%;
  animation: rotate 0.8s linear infinite;
}

@keyframes rotate {
  to {
    transform: rotate(360deg);
  }
}

.empty-icon-wrap {
  width: 132rpx;
  height: 132rpx;
  margin-bottom: 28rpx;
  border-radius: 50%;
  background: #F6F6F6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  width: 72rpx;
  height: 72rpx;
  opacity: 0.65;
}

.state-title {
  color: #333333;
  font-size: 30rpx;
  font-weight: 600;
}

.state-desc {
  max-width: 520rpx;
  margin-top: 16rpx;
  color: #888888;
  font-size: 25rpx;
  line-height: 1.7;
}

.primary-btn {
  margin: 28rpx 0 0;
  padding: 0 42rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 38rpx;
  color: #FFFFFF;
  background: #333333;
  font-size: 27rpx;
}

.compact-btn {
  height: 68rpx;
  line-height: 68rpx;
}

.history-entry {
  margin-top: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  color: #555555;
  background: #FFFFFF;
  font-size: 27rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-arrow {
  color: #BBBBBB;
  font-size: 38rpx;
}
