<view class="page-container">
  <view class="recommend-entry-banner" wx:if="{{smartRecommendEntry}}">
    <text class="banner-title">来自智能推荐</text>
    <text class="banner-text">{{smartRecommendEntry.title}}</text>
  </view>

  <view class="main-board">
    <movable-area class="canvas-area">
      <block wx:for="{{selectedClothes}}" wx:key="index">
        <movable-view 
          class="movable-item" 
          x="{{item.x}}" 
          y="{{item.y}}" 
          direction="all" 
          bindchange="onMoveChange" 
          scale="true" 
          scale-min="0.3" 
          scale-max="3.0" 
          bindscale="onScaleChange"
          data-index="{{index}}"
        >
          <image src="{{item.image}}" class="clothes-img" mode="aspectFit"></image>
          <view class="remove-icon" catchtap="removeClothes" data-index="{{index}}">✕</view>
        </movable-view>
      </block>
    </movable-area>

    <view class="float-action-bar">
      <view class="float-btn model-btn" bindtap="uploadPersonImage">
        <text class="btn-icon">👤</text> 换模特
      </view>
      <view class="float-btn generate-btn" bindtap="startAITryOn">
        <text class="btn-icon">✨</text> AI 试穿
      </view>
    </view>

    <view class="toggle-open-btn {{!sidebarVisible ? 'show' : ''}}" bindtap="toggleSidebar">
      ➜ 衣橱
    </view>
  </view>

  <view class="smart-recommend-fab" bindtap="goToSmartRecommend">
    <image class="smart-recommend-fab-icon" src="{{smartRecommendIcon}}" mode="aspectFit"></image>
  </view>

  <view class="overlay {{sidebarVisible ? 'show' : ''}}" bindtap="toggleSidebar"></view>

  <view class="sidebar {{sidebarVisible ? 'show' : ''}}">
    <view class="sidebar-header">
      <text class="sidebar-title">我的衣橱</text>
      <view class="close-btn" bindtap="toggleSidebar">✕</view>
    </view>

    <view class="search-box">
      <view class="search-inner">
        <icon type="search" size="14" color="#999"></icon>
        <input class="search-input" placeholder="搜索衣服..." bindinput="onSearchInput" value="{{searchKeyword}}" />
      </view>
    </view>

    <scroll-view scroll-x class="category-scroll" enhanced show-scrollbar="{{false}}">
      <view class="category-list">
        <view class="category-item {{currentCategory === '' ? 'active' : ''}}" bindtap="changeCategory" data-category="">全部</view>
        <view class="category-item {{currentCategory === item ? 'active' : ''}}" wx:for="{{categories}}" wx:key="*this" bindtap="changeCategory" data-category="{{item}}">
          {{item}}
        </view>
      </view>
    </scroll-view>

    <scroll-view scroll-y class="clothes-list-scroll">
      <view class="clothes-grid">
        <block wx:for="{{filteredClothes}}" wx:key="_id">
          <view class="clothes-card" bindtap="selectClothes" data-item="{{item}}">
            <image src="{{item.image}}" mode="aspectFill" class="card-img"></image>
            <view class="add-hover">添加</view> 
          </view>
        </block>
        <view class="empty-tip" wx:if="{{filteredClothes.length === 0}}">衣橱空空如也~</view>
      </view>
    </scroll-view>
  </view>
</view>
