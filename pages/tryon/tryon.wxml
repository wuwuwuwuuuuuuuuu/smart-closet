<view class="container">
  
  <view class="sidebar {{sidebarVisible ? 'show' : 'collapsed'}}">
    <view class="sidebar-header">
      <view class="add-btn" bindtap="addClothes">
        <image src="cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img35.png" class="add-icon" />
      </view>
      <view class="search-box">
        <input class="search-input" placeholder="搜索衣物" bindinput="onSearchInput" value="{{searchKeyword}}" />
        <image src="cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img8.png" class="search-icon" />
      </view>
    </view>
    <scroll-view class="season-tabs" scroll-x="true">
      <view class="tabs-container">
        <view class="tab-item {{currentSeason === item ? 'active' : ''}}" wx:for="{{seasons}}" wx:key="*this" bindtap="changeSeason" data-season="{{item}}">{{item}}</view>
      </view>
    </scroll-view>
    <view class="sidebar-content">
      <scroll-view class="category-list" scroll-y="true">
        <view class="category-item {{currentCategory === item ? 'active' : ''}}" wx:for="{{categories}}" wx:key="*this" bindtap="changeCategory" data-category="{{item}}">{{item}}</view>
      </scroll-view>
      <scroll-view class="clothes-grid" scroll-y="true">
        <view class="grid-container">
          <view class="clothes-item" wx:for="{{filteredClothes}}" wx:key="_id" bindtap="selectClothes" data-item="{{item}}">
            <image src="{{item.image}}" class="clothes-image" mode="aspectFill" />
          </view>
          <view class="empty-tip" wx:if="{{filteredClothes.length === 0}}"><text class="empty-text">未找到衣物</text></view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="toggle-btn {{sidebarVisible ? 'open' : 'closed'}}" bindtap="toggleSidebar">
    <text class="arrow">{{sidebarVisible ? '◀' : '▶'}}</text>
  </view>

  <view class="canvas-area">
    <view class="reminder-entry-banner" wx:if="{{smartReminderEntry}}">
      <text class="banner-title">来自智能推荐</text>
      <text class="banner-text">{{smartReminderEntry.title}}</text>
    </view>

    <view class="smart-recommend-fab" bindtap="goToSmartRecommend">
      <image class="smart-recommend-fab-icon" src="{{smartRecommendIcon}}" mode="aspectFit" />
    </view>
    
    <view class="bg-layer" bindtap="uploadPersonImage">
      <image wx:if="{{personImage}}" src="{{personImage}}" class="bg-person" mode="aspectFit" />
      <view class="bg-placeholder" wx:else>
        <view class="plus">+</view>
        <text>点击此处添加模特/人像(可选)</text>
        <text class="sub">添加衣服后，可自由拖拽搭配</text>
      </view>
      <view class="change-person-btn" wx:if="{{personImage}}">换模特</view>
    </view>

    <movable-area class="clothes-board">
      <movable-view 
        class="movable-garment" 
        wx:for="{{selectedClothes}}" 
        wx:key="_id"
        direction="all"
        x="{{item.x}}" 
        y="{{item.y}}"
        bindchange="onMoveChange"
        data-index="{{index}}"
        out-of-bounds="true"
      >
        <image src="{{item.image}}" class="drag-img" mode="aspectFit" />
        <view class="delete-badge" bindtap="removeClothes" data-index="{{index}}">×</view>
      </movable-view>
    </movable-area>

    <view class="action-bar">
      <view class="ai-btn {{isGenerating ? 'disabled' : ''}}" bindtap="startAITryOn">
        <text wx:if="{{!isGenerating}}">✨ 确认搭配，AI上身</text>
        <text wx:else>⏳ AI施法中...</text>
      </view>
    </view>

  </view>
</view>
