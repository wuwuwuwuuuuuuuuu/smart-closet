<!-- 试穿主界面 -->
<view class="container">
  <!-- 左侧折叠按钮 -->
  <view class="toggle-btn {{sidebarVisible ? 'active' : ''}}" bindtap="toggleSidebar">
    <image src="cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img43.png" class="toggle-icon" />
  </view>

  <!-- 侧边栏 -->
  <view class="sidebar {{sidebarVisible ? 'show' : ''}}">
    <!-- 顶部搜索区域 -->
    <view class="sidebar-header">
      <view class="add-btn" bindtap="addClothes">
        <image src="cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img35.png" class="add-icon" />
      </view>
      <view class="search-box">
        <input 
          class="search-input" 
          placeholder="搜索衣物" 
          bindinput="onSearchInput"
          value="{{searchKeyword}}" />
        <image src="cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img8.png" class="search-icon" />
      </view>
    </view>

    <!-- 季节标签 -->
    <scroll-view class="season-tabs" scroll-x="true">
      <view class="tabs-container">
        <view 
          class="tab-item {{currentSeason === item ? 'active' : ''}}" 
          wx:for="{{seasons}}" 
          wx:key="*this"
          bindtap="changeSeason"
          data-season="{{item}}">
          {{item}}
        </view>
      </view>
    </scroll-view>

    <!-- 分类和内容区 -->
    <view class="sidebar-content">
      <!-- 左侧分类 -->
      <scroll-view class="category-list" scroll-y="true">
        <view 
          class="category-item {{currentCategory === item.id ? 'active' : ''}}" 
          wx:for="{{categories}}" 
          wx:key="id"
          bindtap="changeCategory"
          data-category="{{item.id}}">
          {{item.name}}
        </view>
      </scroll-view>

      <!-- 右侧衣物网格 -->
      <scroll-view class="clothes-grid" scroll-y="true">
        <view class="grid-container">
          <view 
            class="clothes-item" 
            wx:for="{{clothesList}}" 
            wx:key="id"
            bindtap="selectClothes"
            data-item="{{item}}">
            <image src="{{item.image}}" class="clothes-image" mode="aspectFill" />
          </view>
          <view class="empty-tip" wx:if="{{clothesList.length === 0}}">
            <text class="empty-text">暂无衣物，快去添加吧！</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 中央试穿区域 -->
  <view class="tryon-area">
    <movable-area class="movable-area">
      <movable-view 
        class="clothes-view" 
        wx:for="{{selectedClothes}}" 
        wx:key="id"
        direction="all"
        x="{{item.x}}" 
        y="{{item.y}}"
        bindchange="onMoveChange"
        data-index="{{index}}">
        <image src="{{item.image}}" class="clothes-preview" mode="aspectFit" />
        <view class="delete-btn" bindtap="removeClothes" data-index="{{index}}">×</view>
      </movable-view>
    </movable-area>
  </view>

  <!-- 右下角确认按钮 -->
  <view class="confirm-btn" bindtap="goToPreview">
    <image src="cloud://cloudbase-2gvrvh4ve926f3d8.636c-cloudbase-2gvrvh4ve926f3d8-1411253050/clothing-images/images/img34.png" class="confirm-icon" />
  </view>
</view>