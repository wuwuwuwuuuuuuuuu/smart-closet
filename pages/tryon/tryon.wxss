page {
  height: 100vh;
  overflow: hidden;
  background: #edf4ef;
}

.page-container {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(90deg, rgba(47, 156, 125, 0.05) 1rpx, transparent 1rpx),
    linear-gradient(0deg, rgba(47, 156, 125, 0.05) 1rpx, transparent 1rpx),
    linear-gradient(180deg, #f7faf6 0%, #eaf3ef 100%);
  background-size: 48rpx 48rpx, 48rpx 48rpx, 100% 100%;
}

.recommend-entry-banner {
  position: absolute;
  top: 28rpx;
  left: 24rpx;
  right: 134rpx;
  z-index: 120;
  padding: 20rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 18rpx 38rpx rgba(37, 49, 44, 0.1);
  backdrop-filter: blur(16px);
}

.banner-title {
  display: block;
  color: #2f9c7d;
  font-size: 26rpx;
  font-weight: 800;
}

.banner-text {
  display: block;
  margin-top: 8rpx;
  color: #5f6d66;
  font-size: 24rpx;
  line-height: 1.5;
}

.main-board {
  width: 100%;
  height: 100%;
  position: absolute;
}

.canvas-area {
  width: 100%;
  height: 100%;
}

.movable-item {
  width: 240rpx;
  height: 320rpx;
  position: relative;
}

.clothes-img {
  width: 100%;
  height: 100%;
}

.remove-icon {
  position: absolute;
  top: -12rpx;
  left: -12rpx;
  width: 46rpx;
  height: 46rpx;
  z-index: 10;
  border-radius: 50%;
  background: #ff5964;
  color: #ffffff;
  text-align: center;
  line-height: 46rpx;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 16rpx rgba(255, 89, 100, 0.28);
}

.float-action-bar {
  position: absolute;
  right: 34rpx;
  bottom: 86rpx;
  z-index: 80;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.float-btn {
  min-width: 210rpx;
  height: 84rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 800;
  box-shadow: 0 16rpx 34rpx rgba(37, 49, 44, 0.13);
  transition: transform 160ms ease, box-shadow 160ms ease;
  backdrop-filter: blur(14px);
}

.float-btn:active {
  transform: scale(0.94);
  box-shadow: 0 8rpx 20rpx rgba(37, 49, 44, 0.12);
}

.model-btn {
  color: #26312c;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}

.generate-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #2f9c7d 0%, #6fb7ff 100%);
  box-shadow: 0 18rpx 36rpx rgba(47, 156, 125, 0.26);
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 34rpx;
}

.toggle-open-btn {
  position: absolute;
  left: -112rpx;
  top: 50%;
  z-index: 80;
  padding: 24rpx 22rpx 24rpx 24rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 10rpx 0 24rpx rgba(37, 49, 44, 0.1);
  backdrop-filter: blur(14px);
  color: #26312c;
  font-size: 26rpx;
  font-weight: 800;
  transform: translateY(-50%);
  transition: left 360ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

.toggle-open-btn.show {
  left: 0;
}

.smart-recommend-fab {
  position: absolute;
  right: 24rpx;
  top: 50%;
  z-index: 110;
  width: 98rpx;
  height: 98rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 18rpx 36rpx rgba(37, 49, 44, 0.14);
  transform: translateY(-50%);
  animation: softFloat 3.2s ease-in-out infinite;
}

.smart-recommend-fab:active {
  transform: translateY(-50%) scale(0.94);
}

.smart-recommend-fab-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  opacity: 0;
  pointer-events: none;
  background: rgba(25, 35, 31, 0.42);
  transition: opacity 300ms ease;
}

.overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.sidebar {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 100;
  width: 560rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  border-radius: 0 38rpx 38rpx 0;
  background: rgba(255, 255, 255, 0.96);
  border-right: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 16rpx 0 44rpx rgba(37, 49, 44, 0.16);
  backdrop-filter: blur(22px);
  transform: translateX(-100%);
  transition: transform 360ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

.sidebar.show {
  transform: translateX(0);
}

.sidebar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 42rpx 32rpx 20rpx;
}

.sidebar-title {
  color: #26312c;
  font-size: 34rpx;
  font-weight: 900;
}

.close-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #eff5f1;
  color: #6c7871;
  font-size: 24rpx;
  transition: transform 160ms ease, background 160ms ease;
}

.close-btn:active {
  transform: scale(0.92);
  background: #e2eee8;
}

.search-box {
  width: 100%;
  padding: 10rpx 32rpx 20rpx;
}

.search-inner {
  height: 72rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  padding: 0 24rpx;
  background: #f3f7f4;
}

.search-input {
  flex: 1;
  min-width: 0;
  margin-left: 14rpx;
  color: #26312c;
  font-size: 26rpx;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
  padding: 0 32rpx;
  margin-bottom: 22rpx;
}

.category-list {
  display: flex;
}

.category-item {
  display: inline-block;
  margin-right: 18rpx;
  padding: 13rpx 26rpx;
  border-radius: 999rpx;
  background: #f2f6f3;
  color: #637068;
  font-size: 24rpx;
  font-weight: 700;
  transition: transform 160ms ease, background 160ms ease;
}

.category-item.active {
  color: #ffffff;
  background: linear-gradient(135deg, #2f9c7d 0%, #6fb7ff 100%);
  box-shadow: 0 10rpx 22rpx rgba(47, 156, 125, 0.2);
}

.category-item:active {
  transform: scale(0.94);
}

.clothes-list-scroll {
  flex: 1;
  width: 100%;
  overflow-y: auto;
  padding: 0 32rpx 44rpx;
}

.clothes-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.clothes-card {
  width: 47%;
  height: 224rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  position: relative;
  border-radius: 24rpx;
  background: #f0f5f1;
  border: 1rpx solid rgba(38, 49, 44, 0.05);
  box-shadow: 0 10rpx 22rpx rgba(37, 49, 44, 0.07);
  transition: transform 160ms ease;
}

.clothes-card:active {
  transform: scale(0.96);
}

.card-img {
  width: 100%;
  height: 100%;
}

.add-hover {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  padding: 8rpx 0;
  border-radius: 999rpx;
  opacity: 0;
  background: rgba(38, 49, 44, 0.62);
  color: #ffffff;
  font-size: 22rpx;
  text-align: center;
  transition: opacity 160ms ease;
}

.clothes-card:active .add-hover {
  opacity: 1;
}

.empty-tip {
  width: 100%;
  margin-top: 100rpx;
  text-align: center;
  color: #9aa59f;
  font-size: 26rpx;
}
