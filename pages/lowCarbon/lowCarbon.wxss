page {
  min-height: 100%;
  background: #EDEDED;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.page-title {
  display: block;
  margin-bottom: 24rpx;
  color: #333333;
  font-size: 36rpx;
  font-weight: 600;
}

.metric-card,
.empty-wardrobe,
.loading-state,
.error-state {
  margin-bottom: 24rpx;
  padding: 30rpx 32rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  box-sizing: border-box;
}

.idle-card,
.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title,
.card-value,
.card-desc {
  display: block;
}

.card-title {
  color: #333333;
  font-size: 30rpx;
  font-weight: 600;
}

.card-value {
  margin-top: 14rpx;
  color: #C65E82;
  font-size: 44rpx;
  font-weight: 600;
}

.detail-link,
.arrow {
  color: #888888;
  font-size: 25rpx;
}

.arrow {
  margin-left: 8rpx;
  font-size: 36rpx;
}

.rate-value {
  color: #C65E82;
  font-size: 40rpx;
  font-weight: 600;
}

.progress-track {
  height: 16rpx;
  margin-top: 26rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: #F1F1F1;
}

.progress-value {
  height: 100%;
  max-width: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #E8A7BC, #C65E82);
}

.card-desc {
  margin-top: 16rpx;
  color: #888888;
  font-size: 24rpx;
  line-height: 1.5;
}

.suggestion-list {
  margin-top: 20rpx;
}

.suggestion-item {
  padding: 13rpx 0;
  color: #666666;
  font-size: 25rpx;
  line-height: 1.6;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.suggestion-dot {
  flex: none;
  width: 10rpx;
  height: 10rpx;
  margin-top: 15rpx;
  border-radius: 50%;
  background: #C65E82;
}

.empty-wardrobe,
.loading-state,
.error-state {
  min-height: 280rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: #888888;
  text-align: center;
}

.empty-icon {
  width: 84rpx;
  height: 84rpx;
  opacity: 0.65;
}

.state-title {
  color: #333333;
  font-size: 30rpx;
  font-weight: 600;
}

.primary-btn {
  margin: 4rpx 0 0;
  padding: 0 42rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  color: #FFFFFF;
  background: #333333;
  font-size: 26rpx;
}

.primary-btn::after {
  border: none;
}

.loading-dot {
  width: 34rpx;
  height: 34rpx;
  border: 5rpx solid #F2D8E1;
  border-top-color: #C65E82;
  border-radius: 50%;
  animation: rotate 0.8s linear infinite;
}

@keyframes rotate {
  to {
    transform: rotate(360deg);
  }
}
