/* 个人信息设置页面样式 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}



/* 头像编辑区 */
.avatar-section {
  padding: 80rpx 0 40rpx;
  display: flex;
  justify-content: center;
}

.avatar-container {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.avatar-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #EDEDED;
}

.edit-button {
  position: absolute;
  right: -8rpx;
  bottom: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F1FF 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 232, 232, 0.3);
}

.edit-icon {
  width: 20rpx;
  height: 20rpx;
}

/* 信息录入表单 */
.form-section {
  margin: 0 20rpx;
}

.form-item {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #E0E0E0;
  padding: 0;
}

.item-label {
  font-size: 28rpx;
  color: #333333;
}

.item-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-value {
  font-size: 28rpx;
  color: #333333;
}

.item-value.placeholder {
  color: #999999;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 底部保存按钮 */
.save-section {
  padding: 60rpx 20rpx 40rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: #EDEDED;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.save-btn.active {
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F1FF 100%);
}

.save-text {
  font-size: 32rpx;
  color: #999999;
  font-weight: 600;
}

.save-btn.active .save-text {
  color: #FFFFFF;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 999;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 40rpx;
  width: 600rpx;
  max-width: 80%;
  margin: 0 auto;
}

.modal-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  background: #EDEDED;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 32rpx;
}

.gender-options {
  margin-bottom: 32rpx;
}

.gender-option {
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  background: #EDEDED;
  transition: all 0.3s ease;
}

.gender-option.selected {
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F1FF 100%);
}

.gender-text {
  font-size: 28rpx;
  color: #333333;
}

.gender-option.selected .gender-text {
  color: #FFFFFF;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
}

/* 日期选择器样式 */
.date-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 999;
}

.date-picker-modal.show {
  opacity: 1;
  visibility: visible;
}

.date-picker-content {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 40rpx;
  width: 600rpx;
  max-width: 80%;
  margin: 0 auto;
}

.date-picker-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
}

.date-picker {
  margin-bottom: 32rpx;
}

.date-picker-display {
  height: 80rpx;
  background: #EDEDED;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.date-value {
  font-size: 28rpx;
  color: #333333;
}

.date-picker-buttons {
  display: flex;
  gap: 20rpx;
}

.date-picker-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.date-picker-btn.cancel {
  background: #EDEDED;
  color: #666666;
}

.date-picker-btn.confirm {
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F1FF 100%);
  color: #FFFFFF;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  background: #EDEDED;
  color: #666666;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F1FF 100%);
  color: #FFFFFF;
}