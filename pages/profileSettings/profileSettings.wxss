/* 个人信息设置页面样式 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

/* 头像编辑区 */
.avatar-section {
  padding: 80rpx 0 40rpx;
  display: flex;
  justify-content: center;
}

.avatar-container {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.avatar-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #EDEDED;
}

.edit-button {
  position: absolute;
  right: -8rpx;
  bottom: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F1FF 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 232, 232, 0.3);
}

.edit-icon {
  width: 20rpx;
  height: 20rpx;
}

/* 信息录入表单 */
.form-section {
  margin: 0 20rpx;
}

.form-item {
  height: 88rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #E0E0E0;
  padding: 0;
}

.item-label {
  font-size: 28rpx;
  color: #333333;
  min-width: 120rpx;
}

.item-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.item-value {
  font-size: 28rpx;
  color: #333333;
}

.item-value.placeholder {
  color: #999999;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 昵称直接输入框 */
.nickname-input-direct {
  width: 100%;
  height: 100%;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  background: transparent;
  border: none;
  outline: none;
}

.nickname-input-direct.placeholder {
  color: #999999;
}

/* 选择器样式 */
.picker-item {
  flex: 1;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.picker-item .item-content {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

/* 底部保存按钮 */
.save-section {
  padding: 60rpx 20rpx 40rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: #EDEDED;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn.active {
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F1FF 100%);
}

.save-text {
  font-size: 32rpx;
  color: #999999;
}

.save-btn.active .save-text {
  color: #333333;
  font-weight: 500;
}

/* 模态框样式 */
.modal-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 999;
  display: none;
}

.modal-container.show {
  display: block;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  padding: 40rpx 32rpx 20rpx;
  text-align: center;
  border-bottom: 1rpx solid #E0E0E0;
}

.modal-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.modal-body {
  padding: 32rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.gender-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.gender-option {
  height: 80rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.gender-option.selected {
  border-color: #FF6B9D;
  background: linear-gradient(135deg, #FFE8E8 0%, #E0F1FF 100%);
}

.gender-text {
  font-size: 28rpx;
  color: #333333;
}

.gender-check {
  color: #FF6B9D;
  font-size: 28rpx;
  display: none;
}

.gender-check.show {
  display: block;
}

.modal-footer {
  display: flex;
  padding: 20rpx 32rpx 40rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.modal-btn.cancel {
  background: #F5F5F5;
  color: #666666;
}

.modal-btn.confirm {
  background: #007AFF;
  color: #FFFFFF;
}

/* 日期选择器样式 */
.date-picker-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 999;
}

.date-picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.date-picker-content {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
}

.date-picker-header {
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #E0E0E0;
}

.date-picker-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.date-picker-actions {
  display: flex;
  gap: 32rpx;
}

.date-picker-btn {
  font-size: 28rpx;
  color: #007AFF;
}

.date-picker-btn.cancel {
  color: #666666;
}