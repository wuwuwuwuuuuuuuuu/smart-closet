<view class="container">

<view class="avatar-section">
  <view class="avatar-container" bindtap="changeAvatar">
    <image src="{{avatarUrl}}" class="avatar-image" mode="aspectFill" />
    <view class="edit-button">
      <image src="/images/icons/edit_icon.png" class="edit-icon" />
    </view>
  </view>
</view>

<view class="form-section">
  <view class="form-item" bindtap="editNickname">
    <text class="item-label">昵称</text>
    <view class="item-content">
      <text class="item-value">{{nickname || '衣橱新主人'}}</text>
      <image src="/images/icons/arrow_right.png" class="arrow-icon" />
    </view>
  </view>

  <view class="form-item" bindtap="showDatePicker">
    <text class="item-label">生日</text>
    <view class="item-content">
      <text class="item-value {{birthday ? '' : 'placeholder'}}">{{birthday || '去选择'}}</text>
      <image src="/images/icons/arrow_right.png" class="arrow-icon" />
    </view>
  </view>

  <view class="form-item" bindtap="selectGender">
    <text class="item-label">性别</text>
    <view class="item-content">
      <text class="item-value {{gender ? '' : 'placeholder'}}">{{gender || '去选择'}}</text>
      <image src="/images/icons/arrow_right.png" class="arrow-icon" />
    </view>
  </view>
</view>

<view class="save-section">
  <view class="save-btn {{canSave ? 'active' : ''}}" bindtap="saveProfile">
    <text class="save-text">保存</text>
  </view>
</view>

</view>