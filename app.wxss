page {
  min-height: 100vh;
  background: #f4f7f4;
  color: #26312c;
  font-family: PingFang SC, -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

view,
scroll-view,
swiper,
swiper-item,
image,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
  line-height: 1.4;
}

button::after {
  border: 0;
}

.page-container,
.login-container {
  animation: pageEnter 480ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.container {
  min-height: 100vh;
  padding: 0 24rpx;
  background: transparent;
}

.card,
.surface-card,
.glass-card {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 46rpx rgba(37, 49, 44, 0.08);
}

.card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.glass-card {
  backdrop-filter: blur(16px);
}

.btn,
.btn-primary,
.primary-btn {
  min-height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #2f9c7d 0%, #6fb7ff 100%);
  box-shadow: 0 16rpx 32rpx rgba(47, 156, 125, 0.22);
  transition: transform 180ms ease, opacity 180ms ease, box-shadow 180ms ease;
}

.btn:active,
.btn-primary:active,
.primary-btn:active,
.pressable:active {
  transform: scale(0.97);
  opacity: 0.92;
}

.input,
.form-input,
.contact-input,
.feedback-textarea,
.tag-input,
.nickname-input {
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(47, 156, 125, 0.12);
  border-radius: 22rpx;
  color: #26312c;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
}

.input::placeholder,
.placeholder,
.search-placeholder {
  color: #97a29b;
}

.divider {
  height: 1rpx;
  background: rgba(38, 49, 44, 0.08);
  margin: 24rpx 0;
}

.text-primary {
  color: #26312c;
  font-size: 32rpx;
  font-weight: 700;
}

.text-normal {
  color: #3c4842;
  font-size: 28rpx;
}

.text-secondary {
  color: #7f8c85;
  font-size: 24rpx;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.icon {
  width: 44rpx;
  height: 44rpx;
}

.image {
  border-radius: 24rpx;
}

.clickable {
  min-width: 44rpx;
  min-height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fade-up {
  animation: fadeUp 520ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.pop-in {
  animation: popIn 420ms cubic-bezier(0.18, 0.9, 0.22, 1.2) both;
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(28rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes popIn {
  from {
    opacity: 0;
    transform: scale(0.94);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes softFloat {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}

@keyframes softPulse {
  0%, 100% {
    box-shadow: 0 16rpx 32rpx rgba(47, 156, 125, 0.2);
  }
  50% {
    box-shadow: 0 20rpx 42rpx rgba(111, 183, 255, 0.28);
  }
}
