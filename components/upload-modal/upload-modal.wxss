/* 服饰上传弹窗样式 */
.upload-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 9999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.upload-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 100%;
  height: 70vh;
  background: #FFFFFF;
  border-radius: 12rpx 12rpx 0 0;
  overflow: hidden;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.upload-modal.show .modal-content {
  transform: translateY(0);
}

/* 上半区：拍照引导预览区 */
.preview-section {
  height: 50%;
  position: relative;
}

.preview-overlay {
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-frame {
  width: 80%;
  height: 80%;
  border: 2rpx solid #333333;
  border-radius: 12rpx 12rpx 0 0;
  overflow: hidden;
  position: relative;
}

.guide-image {
  width: 100%;
  height: 100%;
}

.countdown {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 10;
}

.countdown-number {
  font-size: 48rpx;
  font-weight: 600;
  color: #333333;
  text-shadow: 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
}

.guide-text {
  position: absolute;
  bottom: 32rpx;
  left: 0;
  right: 0;
  text-align: center;
  z-index: 10;
}

.main-guide {
  font-size: 28rpx;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
}

.sub-guide {
  font-size: 24rpx;
  color: #999999;
  display: block;
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
}

/* 进度条 */
.progress-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #E0E0E0;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #E0F7E9 0%, #4CAF50 100%);
  transition: width 0.3s ease;
}

/* 下半区：上传选项列表 */
.options-section {
  height: 50%;
  padding: 32rpx;
}

.title-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  font-family: PingFang SC;
}

.fast-upload-switch {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.switch-label {
  font-size: 24rpx;
  color: #666666;
}

.upload-options {
  margin-bottom: 32rpx;
}

.option-item {
  background: #EDEDED;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
}

.option-item:active {
  background: #E0E0E0;
  transform: scale(0.98);
}

.option-text {
  font-size: 28rpx;
  color: #333333;
  font-family: PingFang SC;
}

.cancel-btn {
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  border: 1rpx solid #E0E0E0;
}

.cancel-text {
  font-size: 28rpx;
  color: #666666;
  font-family: PingFang SC;
}